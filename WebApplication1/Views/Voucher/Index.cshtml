@model List<CarShop.Models.Voucher>
@{
    ViewData["Title"] = "Voucher của tôi";
}
<div class="container mt-4">
    <h2>Voucher đã đổi</h2>
    @if (Model.Any())
    {
        <div class="row">
            @foreach (var v in Model)
            {
                <div class="col-md-3 mb-3">
                    <div class="card">
                        <div class="card-body">
                            <h5>@v.TENVOUCHER</h5>
                            <p>Mã: @v.MAVOUCHER</p>
                            <p>Giá trị: @v.GIATRI.ToString("N0") @(v.LOAI == "Tiền" ? "VNĐ" : "%")</p>
                            <p>HSD: @v.NGAYKETTHUC?.ToString("dd/MM/yyyy")</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <p>Bạn chưa đổi voucher nào.</p>
    }
</div>