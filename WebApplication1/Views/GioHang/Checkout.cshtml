@model CarShop.Models.Cart
@{
    ViewData["Title"] = "Thanh toán";
    var totalAmount = Model.TotalAmount;
}

<div class="container my-5">
    <h2 class="mb-4"><i class="fas fa-credit-card text-primary me-2"></i>Thanh toán đơn hàng</h2>
    
    <div class="row">
        <div class="col-md-7">
            <!-- Form Đặt Hàng -->
            <form id="checkoutForm" method="post" asp-action="PlaceOrder" asp-controller="GioHang">
                @Html.AntiForgeryToken()
                
                <!-- 1. Thông tin giao hàng -->
                <div class="card shadow-sm mb-4 border-0 rounded-4">
                    <div class="card-header bg-primary text-white fw-bold" style="border-radius: 12px 12px 0 0;">
                        <i class="fas fa-map-marker-alt me-2"></i> 1. Thông tin giao hàng
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Địa chỉ giao hàng <span class="text-danger">*</span></label>
                            <textarea name="diaChiGiao" class="form-control" rows="2" required placeholder="Ví dụ: Số 123, đường Lê Lợi, Phường Bến Thành, Quận 1, TP.HCM"></textarea>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Ghi chú (tùy chọn)</label>
                            <textarea name="ghiChu" class="form-control" rows="2" placeholder="Yêu cầu đặc biệt khi giao xe..."></textarea>
                        </div>
                    </div>
                </div>

                <!-- 2. Phương thức thanh toán -->
                <div class="card shadow-sm mb-4 border-0 rounded-4">
                    <div class="card-header bg-primary text-white fw-bold" style="border-radius: 12px 12px 0 0;">
                        <i class="fas fa-wallet me-2"></i> 2. Phương thức thanh toán
                    </div>
                    <div class="card-body">
                        <div class="form-check border rounded p-3 mb-2 bg-light">
                            <input class="form-check-input ms-1" type="radio" name="phuongThucThanhToan" id="paymentCOD" value="COD" checked>
                            <label class="form-check-label ms-2 fw-bold text-dark w-100 cursor-pointer" for="paymentCOD">
                                <i class="fas fa-money-bill-wave text-success me-2"></i> Thanh toán khi nhận hàng (Tiền mặt)
                                <div class="text-muted small mt-1 fw-normal">Thanh toán toàn bộ số tiền khi xe được giao.</div>
                            </label>
                        </div>
                        <div class="form-check border rounded p-3">
                            <input class="form-check-input ms-1" type="radio" name="phuongThucThanhToan" id="paymentBank" value="BANK">
                            <label class="form-check-label ms-2 fw-bold text-dark w-100 cursor-pointer" for="paymentBank">
                                <i class="fas fa-university text-primary me-2"></i> Chuyển khoản ngân hàng
                                <div class="text-muted small mt-1 fw-normal">Nhân viên sẽ liên hệ để gửi thông tin chuyển khoản.</div>
                            </label>
                        </div>
                    </div>
                </div>

                <!-- 3. Mã giảm giá -->
                <div class="card shadow-sm mb-4 border-0 rounded-4">
                    <div class="card-header bg-primary text-white fw-bold" style="border-radius: 12px 12px 0 0;">
                        <i class="fas fa-ticket-alt me-2"></i> 3. Mã giảm giá
                    </div>
                    <div class="card-body">
                        <label class="form-label">Nhập mã giảm giá (nếu có)</label>
                        <div class="input-group">
                            <input type="text" id="voucherCode" class="form-control" placeholder="Nhập mã voucher...">
                            <button type="button" id="applyVoucherBtn" class="btn btn-outline-primary">Áp dụng</button>
                        </div>
                        <div id="voucherMessage" class="small mt-2 fw-bold"></div>
                        
                        <input type="hidden" id="voucherId" name="voucherId" />
                        <input type="hidden" id="discountAmount" name="discountAmount" value="0" />
                    </div>
                </div>

                <!-- ✅ ĐÃ FIX LỖI: Sửa thẻ <a> thành <button type="submit"> để Form chạy lưu DB -->
                <button type="submit" class="btn btn-danger w-100 mt-2 py-3 fw-bold rounded-pill shadow-sm" style="font-size: 1.1rem;">
                    <i class="fas fa-check-circle me-1"></i> XÁC NHẬN ĐẶT HÀNG
                </button>
            </form>
        </div>

        <div class="col-md-5 mt-4 mt-md-0">
            <div class="card shadow-sm border-0 sticky-top rounded-4" style="top: 100px;">
                <div class="card-header bg-dark text-white fw-bold" style="border-radius: 12px 12px 0 0;">
                    <i class="fas fa-shopping-basket me-2"></i> Tóm tắt đơn hàng
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Sản phẩm</th>
                                <th class="text-center">SL</th>
                                <th class="text-end pe-3">Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td>
                                        <span class="fw-bold text-primary">@item.ProductName</span>
                                    </td>
                                    <td class="text-center">@item.Quantity</td>
                                    <td class="text-end text-danger fw-bold pe-3">@((item.Price * item.Quantity).ToString("N0")) đ</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="bg-light">
                            <tr>
                                <td colspan="2" class="text-end fw-bold text-secondary">Tạm tính:</td>
                                <td class="text-end fw-bold pe-3">
                                    <span id="subtotal">@totalAmount.ToString("N0")</span> đ
                                </td>
                            </tr>
                            <tr id="discountRow" style="display: none;">
                                <td colspan="2" class="text-end fw-bold text-success">Khuyến mãi:</td>
                                <td class="text-end fw-bold text-success pe-3">
                                    -<span id="discountValue">0</span> đ
                                </td>
                            </tr>
                            <tr>
                                <td colspan="2" class="text-end fw-bold fs-5 text-dark">TỔNG CỘNG:</td>
                                <td class="text-end fw-bold fs-5 text-danger pe-3">
                                    <span id="finalTotal">@totalAmount.ToString("N0")</span> đ
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            var originalTotal = @totalAmount;

            $('#applyVoucherBtn').click(function() {
                var code = $('#voucherCode').val().trim();
                if (!code) {
                    $('#voucherMessage').html('<span class="text-danger"><i class="fas fa-exclamation-circle"></i> Vui lòng nhập mã</span>');
                    return;
                }
                
                var btn = $(this);
                var originalText = btn.text();
                btn.html('<i class="fas fa-spinner fa-spin"></i>').prop('disabled', true);

                $.ajax({
                    url: '/GioHang/ApplyVoucher',
                    type: 'POST',
                    data: { code: code },
                    headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() },
                    success: function(res) {
                        btn.html(originalText).prop('disabled', false);
                        
                        if (res.success) {
                            $('#voucherMessage').html('<span class="text-success"><i class="fas fa-check-circle"></i> ' + res.message + '</span>');
                            $('#voucherId').val(res.voucherId);
                            $('#discountAmount').val(res.discount);
                            var discount = res.discount;
                            $('#discountValue').text(discount.toLocaleString('vi-VN'));
                            $('#discountRow').show();
                            var final = originalTotal - discount;
                            if(final < 0) final = 0;
                            $('#finalTotal').text(final.toLocaleString('vi-VN'));
                        } else {
                            $('#voucherMessage').html('<span class="text-danger"><i class="fas fa-times-circle"></i> ' + res.message + '</span>');
                            $('#voucherId').val('');
                            $('#discountAmount').val('0');
                            $('#discountRow').hide();
                            $('#finalTotal').text(originalTotal.toLocaleString('vi-VN'));
                        }
                    },
                    error: function() {
                        btn.html(originalText).prop('disabled', false);
                        $('#voucherMessage').html('<span class="text-danger"><i class="fas fa-exclamation-triangle"></i> Lỗi kết nối, vui lòng thử lại!</span>');
                    }
                });
            });
        });
    </script>
}