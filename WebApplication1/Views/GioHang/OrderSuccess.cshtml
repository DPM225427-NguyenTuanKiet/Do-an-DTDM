@{
    ViewData["Title"] = "Đặt hàng thành công";
    var orderId = ViewBag.OrderId;
}

<div class="container my-5 text-center">
    <div class="card shadow-sm p-5">
        <i class="fas fa-check-circle text-success" style="font-size: 80px;"></i>
        <h2 class="mt-3">Đặt hàng thành công!</h2>
        <p>Cảm ơn bạn đã mua hàng. Đơn hàng #@orderId của bạn đã được ghi nhận.</p>
        <p>Chúng tôi sẽ liên hệ xác nhận trong thời gian sớm nhất.</p>
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Tiếp tục mua sắm</a>
        <a asp-controller="DonHang" asp-action="OrderDetail" asp-route-id="@orderId" class="btn btn-outline-secondary mt-2">Xem chi tiết đơn hàng</a>
    </div>
</div>