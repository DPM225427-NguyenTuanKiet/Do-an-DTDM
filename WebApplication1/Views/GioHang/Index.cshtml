@model CarShop.Models.Cart
@{
    ViewData["Title"] = "Giỏ hàng của bạn";
}

<div class="container my-5">
    <h2 class="mb-4"><i class="fas fa-shopping-cart text-danger me-2"></i>Giỏ hàng</h2>

    @if (Model.Items.Any())
    {
        <div class="row">
            <div class="col-lg-8">
                <div class="card shadow-sm border-0 rounded-4">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr class="text-center">
                                        <th style="width: 40%">Sản phẩm</th>
                                        <th style="width: 20%">Đơn giá</th>
                                        <th style="width: 20%">Số lượng</th>
                                        <th style="width: 20%">Thành tiền</th>
                                        <th style="width: 10%"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.Items)
                                    {
                                        <tr class="text-center align-middle">
                                            <td class="text-start">
                                                <div class="d-flex align-items-center gap-3">
                                                    <div class="product-img bg-light rounded-2 p-2" style="width: 60px; height: 60px;">
                                                        <i class="fas fa-car fa-2x text-secondary"></i>
                                                    </div>
                                                    <div>
                                                        <h6 class="mb-0 fw-semibold">@item.ProductName</h6>
                                                        <small class="text-muted">Mã SP: @item.ProductId</small>
                                                    </div>
                                                </div>
                                            </td>
                                            <td class="fw-medium">@item.Price.ToString("N0") ₫</td>
                                            <td>
                                                <div class="input-group input-group-sm justify-content-center" style="max-width: 130px; margin: 0 auto;">
                                                    <button class="btn btn-outline-secondary btn-qty-minus" data-id="@item.ProductId" type="button">−</button>
                                                    <input type="number" class="form-control text-center qty-input border-secondary" data-id="@item.ProductId" value="@item.Quantity" min="1" max="99" style="width: 50px;">
                                                    <button class="btn btn-outline-secondary btn-qty-plus" data-id="@item.ProductId" type="button">+</button>
                                                </div>
                                            </td>
                                            <td class="fw-bold text-danger">
                                                @((item.Price * item.Quantity).ToString("N0")) ₫
                                            </td>
                                            <td>
                                                <button class="btn btn-sm btn-outline-danger rounded-circle remove-item" data-id="@item.ProductId" title="Xóa">
                                                    <i class="fas fa-trash-alt"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <div class="card-footer bg-white border-0 pt-3 pb-3 d-flex justify-content-between align-items-center">
                        <button id="clear-cart" class="btn btn-outline-secondary">
                            <i class="fas fa-trash-alt me-1"></i> Xóa toàn bộ
                        </button>
                        <small class="text-muted"><i class="fas fa-info-circle"></i> Phí vận chuyển sẽ được tính ở bước thanh toán</small>
                    </div>
                </div>
            </div>

            <div class="col-lg-4 mt-4 mt-lg-0">
                <div class="card shadow-sm border-0 rounded-4">
                    <div class="card-header bg-white border-0 pt-4 pb-0">
                        <h5 class="mb-0"><i class="fas fa-receipt me-2"></i>Thông tin đơn hàng</h5>
                    </div>
                    <div class="card-body">
                        <div class="d-flex justify-content-between mb-2">
                            <span>Tạm tính:</span>
                            <span class="fw-medium">@Model.TotalAmount.ToString("N0") ₫</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2 text-muted">
                            <span>Phí vận chuyển:</span>
                            <span>Tính sau</span>
                        </div>
                        <hr>
                        <div class="d-flex justify-content-between mb-4">
                            <strong>Tổng cộng:</strong>
                            <strong class="text-danger fs-5">@Model.TotalAmount.ToString("N0") ₫</strong>
                        </div>
                        <a asp-action="Checkout" asp-controller="GioHang" class="btn btn-danger w-100 py-2 fw-semibold rounded-3">
                            <i class="fas fa-credit-card me-2"></i> Tiến hành thanh toán
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5 bg-light rounded-4">
            <i class="fas fa-shopping-cart fa-4x text-muted mb-3"></i>
            <h4 class="text-muted">Giỏ hàng của bạn đang trống</h4>
            <p class="text-muted">Hãy thêm sản phẩm để tiếp tục mua sắm.</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary mt-2">
                <i class="fas fa-arrow-left me-1"></i> Tiếp tục mua sắm
            </a>
        </div>
    }
</div>

@section Scripts {
    <script src="~/js/features.js"></script>
    <script>
        // Xử lý nút + / - cho số lượng (tương thích với functions có sẵn)
        $(document).ready(function() {
            // Giảm số lượng
            $('.btn-qty-minus').click(function() {
                var id = $(this).data('id');
                var input = $(this).siblings('.qty-input');
                var val = parseInt(input.val());
                if (val > 1) {
                    input.val(val - 1).trigger('change');
                }
            });
            // Tăng số lượng
            $('.btn-qty-plus').click(function() {
                var id = $(this).data('id');
                var input = $(this).siblings('.qty-input');
                var val = parseInt(input.val());
                if (val < 99) {
                    input.val(val + 1).trigger('change');
                }
            });
            // Bắt sự kiện change để cập nhật giỏ hàng (sử dụng hàm updateQuantity có sẵn)
            $('.qty-input').change(function() {
                var id = $(this).data('id');
                var qty = $(this).val();
                if (qty < 1) qty = 1;
                updateQuantity(id, qty); // Hàm này có trong features.js
            });
        });
    </script>
}