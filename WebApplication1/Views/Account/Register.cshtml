@model CarShop.Models.TaiKhoan
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng ký - CarShop</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="~/css/login.css">
    </head>
    <body>
        <div class="auth-container">
            <div class="auth-header">
                <h1>🚗 CarShop</h1>
                <p>Tạo tài khoản mới</p>
            </div>
            <div class="auth-body">
                @if (!string.IsNullOrEmpty(ViewBag.Error))
                {
                    <div class="alert alert-danger">@ViewBag.Error</div>
                }
                <form method="post" id="registerForm">
                    <div class="form-group">
                        <label>Tên đăng nhập</label>
                        <div class="input-wrapper">
                            <i class="fas fa-user"></i>
                            <input asp-for="TENDANGNHAP" required>
                            </div>
                        </div>
                        <div class="form-group">
                            <label>Email</label>
                            <div class="input-wrapper">
                                <i class="fas fa-envelope"></i>
                                <input asp-for="EMAIL" type="email" required>
                                </div>
                            </div>
                            <div class="form-group">
                                <label>Mật khẩu</label>
                                <div class="input-wrapper">
                                    <i class="fas fa-lock"></i>
                                    <input asp-for="MATKHAU" type="password" id="MatKhau" required>
                                        <button type="button" class="toggle-password" data-target="MatKhau"><i class="fas fa-eye"></i></button>
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label>Xác nhận mật khẩu</label>
                                    <div class="input-wrapper">
                                        <i class="fas fa-lock"></i>
                                        <input type="password" id="ConfirmPassword" required>
                                        <button type="button" class="toggle-password" data-target="ConfirmPassword"><i class="fas fa-eye"></i></button>
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label>Họ tên</label>
                                    <div class="input-wrapper">
                                        <i class="fas fa-id-card"></i>
                                        <input name="hoten" required>
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label>Số điện thoại</label>
                                    <div class="input-wrapper">
                                        <i class="fas fa-phone"></i>
                                        <input name="dienthoai" required>
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label>Địa chỉ</label>
                                    <div class="input-wrapper">
                                        <i class="fas fa-map-marker-alt"></i>
                                        <input name="diachi" required>
                                    </div>
                                </div>
                                <button type="submit" class="btn-submit">Đăng ký</button>
                            </form>
                            <div class="auth-links">
                                <a asp-action="Login">Đã có tài khoản? Đăng nhập</a>
                            </div>
                        </div>
                    </div>
                    <script src="~/js/login.js"></script>
                    <script>
                            // Xác nhận mật khẩu
                            const form = document.getElementById('registerForm');
                            form.addEventListener('submit', function(e) {
                                const pwd = document.getElementById('MatKhau').value;
                                const confirm = document.getElementById('ConfirmPassword').value;
                                if (pwd !== confirm) {
                                    e.preventDefault();
                                    alert('Mật khẩu xác nhận không khớp');
                                }
                            });
                    </script>
                </body>
            </html>