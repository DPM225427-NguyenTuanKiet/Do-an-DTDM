@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng nhập - CarShop</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="~/css/login.css">
    </head>
    <body>
        <div class="auth-container">
            <div class="auth-header">
                <h1>🚗 CarShop</h1>
                <p>Đăng nhập để tiếp tục</p>
            </div>
            <div class="auth-body">
                @if (!string.IsNullOrEmpty(ViewBag.Error))
                {
                    <div class="alert alert-danger">@ViewBag.Error</div>
                }
                @if (TempData["Message"] != null)
                {
                    <div class="alert alert-success">@TempData["Message"]</div>
                }
                <form method="post" asp-action="Login">
                    <div class="form-group">
                        <label>Tên đăng nhập</label>
                        <div class="input-wrapper">
                            <i class="fas fa-user"></i>
                            <input type="text" name="username" required autofocus>
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Mật khẩu</label>
                        <div class="input-wrapper">
                            <i class="fas fa-lock"></i>
                            <input type="password" name="password" id="password" required>
                            <button type="button" class="toggle-password" data-target="password"><i class="fas fa-eye"></i></button>
                        </div>
                    </div>
                    <button type="submit" class="btn-submit">Đăng nhập</button>
                </form>
                <div class="auth-links">
                    <a asp-action="Register">Chưa có tài khoản? Đăng ký</a>
                    <a asp-action="ForgotPassword">Quên mật khẩu?</a>
                </div>
            </div>
        </div>
        <script src="~/js/login.js"></script>
    </body>
</html>