@model CarShop.Models.TaiKhoan
@{
    ViewData["Title"] = "Thông tin tài khoản";
    var khachHang = ViewBag.KhachHang as CarShop.Models.KhachHang;
}
<div class="container mt-4">
    <div class="row g-4">
        <!-- Cập nhật lại khu vực Avatar trong Profile.cshtml -->
        <div class="position-relative d-inline-block">
            <img id="avatar-preview" src="@(khachHang?.AVATAR ?? "/images/avatar-default.png")"
                 class="rounded-circle img-fluid" style="width: 140px; height: 140px; object-fit: cover; border: 4px solid #fff; box-shadow: 0 5px 15px rgba(0,0,0,0.1);">
    
            <button type="button" id="uploadAvatarBtn" class="btn btn-sm btn-light position-absolute bottom-0 end-0 rounded-circle shadow" style="width: 36px; height: 36px;">
                <i class="fas fa-camera"></i>
            </button>
    
            <!-- THÊM DÒNG NÀY: Input ẩn để chọn file -->
            <input type="file" id="avatarFile" accept="image/png, image/jpeg, image/jpg" style="display: none;" />
        </div>
        <!-- Thông tin tài khoản -->
        <div class="col-md-8">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-header bg-white border-0 pt-4 pb-0">
                    <h5 class="mb-0"><i class="fas fa-user-edit me-2"></i>Thông tin tài khoản</h5>
                </div>
                <div class="card-body p-4">
                    @if (TempData["Message"] != null)
                    {
                        <div class="alert alert-success">@TempData["Message"]</div>
                    }
                    <form method="post" asp-action="Profile">
                        <div class="mb-3">
                            <label class="form-label">Tên đăng nhập</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="fas fa-user"></i></span>
                                <input class="form-control" value="@Model.TENDANGNHAP" disabled>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label asp-for="EMAIL" class="form-label">Email</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="fas fa-envelope"></i></span>
                                <input asp-for="EMAIL" class="form-control" required>
                                </div>
                                <span asp-validation-for="EMAIL" class="text-danger"></span>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Họ tên</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light"><i class="fas fa-user"></i></span>
                                    <input type="text" name="hoten" class="form-control" value="@(khachHang?.HOTEN ?? "")" required>
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Số điện thoại</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light"><i class="fas fa-phone"></i></span>
                                    <input type="text" name="dienthoai" class="form-control" value="@(khachHang?.DIENTHOAI ?? "")" required>
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Địa chỉ</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light"><i class="fas fa-map-marker-alt"></i></span>
                                    <textarea name="diachi" class="form-control" rows="2">@(khachHang?.DIACHI ?? "")</textarea>
                                </div>
                            </div>
                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-primary px-4">Cập nhật</button>
                                <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Quay lại</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
        <script>
            $('#uploadAvatarBtn').click(function() {
                $('#avatarFile').click();
            });
            $('#avatarFile').change(function() {
                var formData = new FormData();
                var file = this.files[0];
                if (!file) return;
                formData.append('avatarFile', file);
                $.ajax({
                    url: '/Account/UploadAvatar',
                    type: 'POST',
                    data: formData,
                    processData: false,
                    contentType: false,
                    success: function(res) {
                        if (res.success) {
                            $('#avatar-preview').attr('src', res.imageUrl + '?t=' + new Date().getTime());
                            Swal.fire('Thành công', 'Cập nhật avatar thành công', 'success');
                        } else {
                            Swal.fire('Lỗi', res.message, 'error');
                        }
                    },
                    error: function() {
                        Swal.fire('Lỗi', 'Có lỗi xảy ra', 'error');
                    }
                });
            });
        </script>
    }