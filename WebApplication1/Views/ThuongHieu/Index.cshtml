@model List<CarShop.Models.ThuongHieu>
@{
    ViewData["Title"] = "Thương hiệu xe";
}

<div class="container my-5">
    <h1 class="text-center mb-4">🏷️ Thương hiệu xe</h1>
    <div class="row g-4">
        @foreach (var th in Model)
        {
            <div class="col-md-3 col-sm-6">
                <div class="card h-100 shadow-sm text-center">
                    <div class="card-body">
                        <i class="fas fa-trademark fa-3x text-primary mb-3"></i>
                        <h5 class="card-title">@th.TENTHUONGHIEU</h5>
                        <p class="small text-muted">@(th.QUOCGIA ?? "")</p>
                        <a asp-action="SanPhamTheoThuongHieu" asp-route-id="@th.IDTH" class="btn btn-outline-primary btn-sm">
                            Xem xe <i class="fas fa-arrow-right"></i>
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>