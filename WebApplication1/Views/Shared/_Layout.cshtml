@using CarShop.Models
@using CarShop.Extensions
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CarShop</title>
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/home.css" />
    <!-- SweetAlert2 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body>
    <header>
        <!-- Top bar (giữ nguyên) -->
        <div class="top-bar">
            <div class="container">
                <div class="row align-items-center">
                    <div class="col-md-6">
                        <div class="contact-info">
                            <span><i class="fas fa-phone-alt"></i> Hotline: 1900 6369</span>
                            <span class="ms-3"><i class="fas fa-envelope"></i> carshop@oto.vn</span>
                        </div>
                    </div>
                    <div class="col-md-6 text-end">
                        <div class="social-links">
                            <a href="#"><i class="fab fa-facebook-f"></i></a>
                            <a href="#"><i class="fab fa-instagram"></i></a>
                            <a href="#"><i class="fab fa-youtube"></i></a>
                            <a href="#"><i class="fab fa-tiktok"></i></a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Main Navbar -->
        <nav class="navbar navbar-expand-lg navbar-light bg-white sticky-top shadow-sm">
            <div class="container">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <img src="/images/logo.png" alt="CarShop" height="45">
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav mx-auto">
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")"
                                   asp-controller="Home" asp-action="Index">
                                <i class="fas fa-home"></i> Trang chủ
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="DanhMuc" asp-action="Index">
                                <i class="fas fa-car"></i> Danh mục xe
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="ThuongHieu" asp-action="Index">
                                <i class="fas fa-trademark"></i> Thương hiệu
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Contact">
                                <i class="fas fa-headset"></i> Liên hệ
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="SoSanh" asp-action="Index">
                                <i class="fas fa-balance-scale"></i> So sánh
                            </a>
                        </li>
                    </ul>
                    
                    <ul class="navbar-nav align-items-center">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle user-dropdown" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown">
                                    <img src="/images/avatar-default.png" alt="Avatar" class="avatar-sm rounded-circle me-1">
                                    @User.Identity.Name
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0">
                                    <li><a class="dropdown-item" asp-controller="GioHang" asp-action="Index"><i class="fas fa-shopping-cart"></i> Giỏ hàng</a></li>
                                    <li><a class="dropdown-item" asp-controller="YeuThich" asp-action="Index"><i class="fas fa-heart text-danger"></i> Yêu thích</a></li>
                                    <li><a class="dropdown-item" asp-controller="DonHang" asp-action="History"><i class="fas fa-history"></i> Lịch sử đơn hàng</a></li>
                                    <li><a class="dropdown-item" asp-controller="DiemTichLuy" asp-action="Index"><i class="fas fa-star text-warning"></i> Điểm tích lũy</a></li>
                                    <li><a class="dropdown-item" asp-controller="BaoHanh" asp-action="Index"><i class="fas fa-shield-alt text-info"></i> Bảo hành</a></li>
                                    <li><a class="dropdown-item" asp-controller="DoiDiem" asp-action="Index"><i class="fas fa-exchange-alt"></i> Đổi điểm</a></li>
                                    <li><a class="dropdown-item" asp-controller="YeuCauTraHang" asp-action="Index"><i class="fas fa-undo-alt"></i> Trả hàng</a></li>
                                    <li><a class="dropdown-item" asp-controller="Voucher" asp-action="Index"><i class="fas fa-ticket-alt text-success"></i> Voucher</a></li>
                                    <li><a class="dropdown-item" asp-controller="QuaTang" asp-action="Index"><i class="fas fa-gift text-primary"></i> Quà tặng</a></li>
                                    <li><a class="dropdown-item" asp-controller="LoaiKhachHang" asp-action="Index"><i class="fas fa-crown text-warning"></i> Hạng thành viên</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" asp-controller="Account" asp-action="Profile"><i class="fas fa-id-card"></i> Thông tin tài khoản</a></li>
                                    @if (User.IsInRole("admin"))
                                    {
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item" asp-area="" asp-controller="Dashboard" asp-action="Index"><i class="fas fa-cog"></i> Quản trị</a></li>
                                    }
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="dropdown-item text-danger"><i class="fas fa-sign-out-alt"></i> Đăng xuất</button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <!-- NÚT ĐĂNG NHẬP / ĐĂNG KÝ ĐÃ ĐƯỢC THIẾT KẾ LẠI CHUẨN XÁC -->
                            <li class="nav-item d-flex align-items-center ms-3">
                                <a class="btn-auth btn-login" asp-controller="Account" asp-action="Login">
                                    <i class="fas fa-sign-in-alt"></i> Đăng nhập
                                </a>
                            </li>
                            <li class="nav-item d-flex align-items-center ms-2">
                                <a class="btn-auth btn-register" asp-controller="Account" asp-action="Register">
                                    <i class="fas fa-user-plus"></i> Đăng ký
                                </a>
                            </li>
                        }
                        
                        <!-- Giỏ hàng (Có vạch kẻ ngăn cách cho đẹp) -->
                        <li class="nav-item ms-3 ps-3 border-start d-flex align-items-center">
                            <a class="nav-link cart-icon position-relative p-0" asp-controller="GioHang" asp-action="Index">
                                <i class="fas fa-shopping-cart fa-lg"></i>
                                @{
                                    var cartCount = Context.Session.GetObject<Cart>("Cart")?.Items.Sum(i => i.Quantity) ?? 0;
                                }
                                @if (cartCount > 0)
                                {
                                    <span class="cart-badge">@cartCount</span>
                                }
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>

        <!-- HÀNG TÌM KIẾM RIÊNG -->
        <div class="search-row bg-white border-top py-2 shadow-sm">
            <div class="container">
                <form class="d-flex search-form" asp-controller="Home" asp-action="Search" method="get">
                    <div class="input-group w-100 shadow-sm">
                        <input class="form-control form-control-lg border-0 bg-light" type="search" name="search" placeholder="Bạn muốn tìm xe gì? Nhập tên xe, thương hiệu..." value="@Context.Request.Query["search"]">
                        <button class="btn btn-primary px-4 fw-bold" type="submit">
                            <i class="fas fa-search me-1"></i> Tìm kiếm
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </header>

    <main>
        @RenderBody()
    </main>

    <footer class="footer mt-5">
        <div class="container">
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="footer-logo">
                        <img src="/images/logo-car-white.png" alt="CarShop" height="40">
                        <p class="mt-3">CarShop - Đẳng cấp xe hơi, niềm tin của bạn. Chuyên cung cấp các dòng xe chính hãng, dịch vụ hậu mãi tốt nhất Việt Nam.</p>
                    </div>
                </div>
                <div class="col-md-2">
                    <h5 class="text-white">Về chúng tôi</h5>
                    <ul class="list-unstyled">
                        <li><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                        <li><a href="#">Giới thiệu</a></li>
                        <li><a asp-controller="Home" asp-action="Contact">Liên hệ</a></li>
                        <li><a href="#">Tuyển dụng</a></li>
                    </ul>
                </div>
                <div class="col-md-3">
                    <h5 class="text-white">Hỗ trợ khách hàng</h5>
                    <ul class="list-unstyled">
                        <li><a href="#">Hướng dẫn mua hàng</a></li>
                        <li><a href="#">Chính sách bảo hành</a></li>
                        <li><a href="#">Chính sách đổi trả</a></li>
                        <li><a href="#">Thanh toán & giao nhận</a></li>
                    </ul>
                </div>
                <div class="col-md-3">
                    <h5 class="text-white">Kết nối với chúng tôi</h5>
                    <div class="social-icons mb-3">
                        <a href="#"><i class="fab fa-facebook-f"></i></a>
                        <a href="#"><i class="fab fa-instagram"></i></a>
                        <a href="#"><i class="fab fa-youtube"></i></a>
                        <a href="#"><i class="fab fa-tiktok"></i></a>
                        <a href="#"><i class="fab fa-zalo"></i></a>
                    </div>
                    <div class="contact-footer">
                        <p><i class="fas fa-phone-alt"></i> 1900 6369</p>
                        <p><i class="fas fa-envelope"></i> carshop@oto.vn</p>
                        <p><i class="fas fa-map-marker-alt"></i> 123 Lê Lợi, Q1, TP.HCM</p>
                    </div>
                    <div class="newsletter mt-4">
                        <h6 class="text-white mb-3">Đăng ký nhận khuyến mãi</h6>
                        <form id="newsletterForm" method="post" asp-controller="Newsletter" asp-action="Subscribe">
                            <div class="input-group">
                                <input type="email" name="email" class="form-control border-0" placeholder="Email của bạn" required>
                                <button class="btn btn-primary fw-bold" type="submit">Đăng ký</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
            <hr class="mt-4 mb-3 border-secondary">
            <div class="row align-items-center">
                <div class="col-md-6 text-center text-md-start">
                    <p class="mb-0 text-muted">&copy; 2026 CarShop - Bản quyền thuộc về Hồ Thanh Hận.</p>
                </div>
                <div class="col-md-6 text-center text-md-end mt-3 mt-md-0">
                    <img src="/images/payment-methods.png" alt="Payment" height="30" class="img-fluid opacity-75">
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/features.js"></script>
    <script>
        // Newsletter AJAX
        document.getElementById('newsletterForm')?.addEventListener('submit', async function(e) {
        e.preventDefault();
        const form = e.target;
        const formData = new FormData(form);
        const response = await fetch(form.action, { method: 'POST', body: formData });
        const result = await response.json();
        if (result.success) {
            Swal.fire('Thành công', result.message, 'success');
            form.reset();
        } else {
                Swal.fire('Lỗi', result.message, 'error');
        }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>