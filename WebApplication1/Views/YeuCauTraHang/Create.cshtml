@{
    ViewData["Title"] = "Tạo yêu cầu trả hàng";
    var orders = ViewBag.Orders as List<CarShop.Models.DonHang>;
}
<div class="container mt-4">
    <h2>Tạo yêu cầu trả hàng</h2>
    <form method="post">
        <div class="mb-3">
            <label>Chọn đơn hàng</label>
            <select id="orderSelect" class="form-select">
                <option value="">-- Chọn --</option>
                @foreach (var o in orders)
                {
                    <option value="@o.IDDH">#@o.IDDH - @o.NGAYDAT.ToString("dd/MM/yyyy")</option>
                }
            </select>
        </div>
        <div id="product-list"></div>
        <div class="mb-3">
            <label>Lý do</label>
            <textarea name="reason" class="form-control" required></textarea>
        </div>
        <button type="submit" class="btn btn-primary">Gửi yêu cầu</button>
    </form>
</div>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    $('#orderSelect').change(function() {
    var id = $(this).val();
    if (id) {
    $.get('/YeuCauTraHang/GetOrderItems', { orderId: id }, function(data) {
    $('#product-list').html(data);
    });
    } else $('#product-list').empty();
    });
</script>