@model List<CarShop.Models.DonHang>
@{
    ViewData["Title"] = "Lịch sử đơn hàng";
}
<div class="container mt-4">
    <h2>Lịch sử đơn hàng</h2>
    @if (Model.Any())
    {
        <table class="table table-bordered">
            <thead><tr><th>Mã đơn</th><th>Ngày đặt</th><th>Tổng tiền</th><th>Trạng thái</th><th></th></tr></thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.IDDH</td>
                        <td>@item.NGAYDAT.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@item.TONGTIEN.ToString("N0") VNĐ</td>
                        <td>@item.TRANGTHAI</td>
                        <td><a asp-action="OrderDetail" asp-route-id="@item.IDDH" class="btn btn-sm btn-info">Chi tiết</a></td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p>Chưa có đơn hàng nào.</p>
    }
</div>