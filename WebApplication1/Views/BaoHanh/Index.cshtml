@model List<CarShop.Models.BaoHanh>
@{
    ViewData["Title"] = "Sổ bảo hành điện tử";
    var products = ViewBag.Products as Dictionary<int, CarShop.Models.SanPham>;
}

<div class="container my-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-shield-alt text-primary me-2"></i>Sổ Bảo Hành Điện Tử</h2>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                var sp = products != null && products.ContainsKey(item.IDSP) ? products[item.IDSP] : null;
                
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden warranty-card">
                        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center border-0 py-3">
                            <span class="fw-bold text-truncate pe-2"><i class="fas fa-car me-2"></i> @(sp?.TENSP ?? "Sản phẩm")</span>
                            <span class="badge bg-light text-dark">#@item.IDBH</span>
                        </div>
                        <div class="card-body p-4 position-relative">
                            <!-- Hình mờ làm background -->
                            <i class="fas fa-certificate position-absolute text-light" style="font-size: 8rem; right: -20px; bottom: -20px; opacity: 0.3; z-index: 0;"></i>
                            
                            <div class="position-relative" style="z-index: 1;">
                                <p class="mb-2 text-muted small text-uppercase fw-bold">Thời hạn bảo hành</p>
                                <h5 class="fw-bold text-dark mb-3">
                                    @item.NGAYBATDAU?.ToString("dd/MM/yyyy") - @item.NGAYKETTHUC?.ToString("dd/MM/yyyy")
                                </h5>
                                
                                <p class="mb-2">
                                    <strong>Trạng thái:</strong> 
                                    @if(item.TRANGTHAI == "Đang bảo hành" && item.NGAYKETTHUC >= DateTime.Now) {
                                        <span class="badge bg-success px-2 py-1"><i class="fas fa-check-circle me-1"></i> Có hiệu lực</span>
                                    } else {
                                        <span class="badge bg-danger px-2 py-1"><i class="fas fa-times-circle me-1"></i> Đã hết hạn</span>
                                    }
                                </p>
                                <p class="mb-0 text-muted small"><i class="fas fa-info-circle me-1"></i> @item.MOTA</p>
                            </div>
                        </div>
                        <div class="card-footer bg-white border-0 text-center pb-4 pt-0">
                            <a asp-action="Details" asp-route-id="@item.IDBH" class="btn btn-outline-primary rounded-pill px-4 w-100 fw-bold">
                                Xem thẻ bảo hành
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5 bg-white rounded-4 shadow-sm">
            <i class="fas fa-shield-alt fa-4x text-muted mb-3 opacity-50"></i>
            <h5 class="text-muted">Bạn chưa có sổ bảo hành nào.</h5>
            <p class="text-muted small">Sổ bảo hành sẽ tự động được cấp khi bạn mua xe thành công.</p>
            <a href="/" class="btn btn-primary rounded-pill mt-3 px-4">Khám phá xe ngay</a>
        </div>
    }
</div>

<style>
    .warranty-card { transition: transform 0.3s ease; }
    .warranty-card:hover { transform: translateY(-5px); box-shadow: 0 10px 25px rgba(0,0,0,0.1) !important; }
</style>