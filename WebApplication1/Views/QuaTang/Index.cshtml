@model List<CarShop.Models.QuaTang>
@{
    ViewData["Title"] = "Quà tặng đổi điểm";
}
<div class="container mt-4">
    <h2>Quà tặng đổi điểm</h2>
    <div class="row">
        @foreach (var g in Model)
        {
            <div class="col-md-3 mb-3">
                <div class="card">
                    <div class="card-body">
                        <h5>@g.TENQUATANG</h5>
                        <p>Điểm cần: @g.DIEM_DOI</p>
                        <p>Số lượng còn: @g.SOLUONG</p>
                        @if (User.Identity.IsAuthenticated)
                        {
                            <button class="btn btn-primary exchange-gift" data-id="@g.IDQT">Đổi</button>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>
@section Scripts {
    <script>
        $('.exchange-gift').click(function() {
            var id = $(this).data('id');
            $.post('/DoiDiem/DoiQuaTang', { giftId: id }, function(res) {
                if (res.success) alert('Đổi thành công!'); else alert(res.message);
            });
        });
    </script>
}