@model CarShop.Models.Voucher
@{
    ViewData["Title"] = "Xóa voucher";
    Layout = "_AdminLayout";
}

<div class="card shadow-sm">
    <div class="card-header bg-danger text-white">
        <h4><i class="fas fa-exclamation-triangle"></i> Xác nhận xóa voucher</h4>
    </div>
    <div class="card-body">
        <div class="alert alert-warning">
            <i class="fas fa-info-circle"></i> Bạn có chắc chắn muốn xóa voucher <strong>@Model.TENVOUCHER</strong>? Hành động không thể hoàn tác.
        </div>
        <dl class="row">
            <dt class="col-sm-3">Mã voucher</dt>
            <dd class="col-sm-9">@Model.MAVOUCHER</dd>
            <dt class="col-sm-3">Tên voucher</dt>
            <dd class="col-sm-9">@Model.TENVOUCHER</dd>
            <dt class="col-sm-3">Giá trị</dt>
            <dd class="col-sm-9">
                @if (Model.LOAI == "Tiền")
                {
                    @Model.GIATRI.ToString("N0")
                
                    <text> VNĐ</text>
                }
                else
                {
                    @Model.GIATRI.ToString()
                    
                    <text>%</text>
                }
            </dd>
        </dl>
        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="IDV" />
            <button type="submit" class="btn btn-danger"><i class="fas fa-trash-alt"></i> Xóa</button>
            <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Quay lại</a>
        </form>
    </div>
</div>