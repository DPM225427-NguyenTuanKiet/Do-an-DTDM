@model CarShop.Models.SanPhamKhuyenMai
@{
    ViewData["Title"] = "Sửa liên kết";
    Layout = "_AdminLayout";
    var sanPhams = ViewBag.SanPhams as List<CarShop.Models.SanPham>;
    var khuyenMais = ViewBag.KhuyenMais as List<CarShop.Models.KhuyenMai>;
}

<div class="card shadow-sm">
    <div class="card-header bg-warning text-dark">
        <h4><i class="fas fa-edit"></i> Sửa liên kết</h4>
    </div>
    <div class="card-body">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            <div class="mb-3">
                <label asp-for="IDSP" class="form-label">Sản phẩm</label>
                <select asp-for="IDSP" class="form-select" required>
                    <option value="">-- Chọn sản phẩm --</option>
                    @foreach (var sp in sanPhams)
                    {
                        <option value="@sp.IDSP" selected="@(sp.IDSP == Model.IDSP)">@sp.TENSP</option>
                    }
                </select>
            </div>
            <div class="mb-3">
                <label asp-for="IDKM" class="form-label">Khuyến mãi</label>
                <select asp-for="IDKM" class="form-select" required>
                    <option value="">-- Chọn khuyến mãi --</option>
                    @foreach (var km in khuyenMais)
                    {
                        <option value="@km.IDKM" selected="@(km.IDKM == Model.IDKM)">@km.TENKM</option>
                    }
                </select>
            </div>
            <button type="submit" class="btn btn-orange"><i class="fas fa-save"></i> Lưu thay đổi</button>
            <a asp-action="Index" class="btn btn-secondary">Hủy</a>
        </form>
    </div>
</div>