@model CarShop.Models.YeuCauTraHang
@{
    ViewData["Title"] = "Xử lý yêu cầu trả hàng";
    Layout = "_AdminLayout";
    var kh = ViewBag.KhachHang as CarShop.Models.KhachHang;
    var products = ViewBag.Products as Dictionary<int, CarShop.Models.SanPham>;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-undo-alt me-2"></i>Chi tiết yêu cầu #@Model.IDYCTH</h2>
    <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Quay lại danh sách</a>
</div>

<div class="row">
    <!-- Phân cột thông tin và hình ảnh -->
    <div class="col-md-7">
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-dark text-white fw-bold">Thông tin khách báo cáo</div>
            <div class="card-body">
                <table class="table table-borderless">
                    <tr><td width="30%"><strong>Khách hàng:</strong></td><td>@(kh?.HOTEN ?? "N/A") (SĐT: @kh?.DIENTHOAI)</td></tr>
                    <tr><td><strong>Đơn hàng số:</strong></td><td>#@Model.IDDH</td></tr>
                    <tr><td><strong>Ngày gửi:</strong></td><td>@Model.NGAYYEUCAU?.ToString("dd/MM/yyyy HH:mm")</td></tr>
                    <tr><td><strong>Lý do trả:</strong></td><td class="text-danger fw-bold">@Model.LYDO</td></tr>
                </table>
            </div>
        </div>

        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-secondary text-white fw-bold">Sản phẩm yêu cầu trả</div>
            <div class="card-body p-0">
                <table class="table mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Sản phẩm</th>
                            <th class="text-center">SL</th>
                            <th class="text-end">Giá trị hoàn</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.CHITIET)
                        {
                            var sp = products != null && products.ContainsKey(item.IDSP) ? products[item.IDSP] : null;
                            <tr>
                                <td>@(sp?.TENSP ?? "N/A")</td>
                                <td class="text-center">@item.SOLUONG</td>
                                <td class="text-end text-danger fw-bold">@item.TIENHOAN?.ToString("N0") đ</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Cột xem ảnh và Xử lý -->
    <div class="col-md-5">
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-primary text-white fw-bold">Hình ảnh minh chứng</div>
            <div class="card-body text-center p-2">
                @if (!string.IsNullOrEmpty(Model.HINHANH_MINHCHUNG))
                {
                    <a href="@Model.HINHANH_MINHCHUNG" target="_blank" title="Bấm để xem ảnh gốc">
                        <img src="@Model.HINHANH_MINHCHUNG" class="img-fluid rounded" alt="Proof" style="max-height: 350px; cursor: zoom-in;" />
                    </a>
                }
                else
                {
                    <p class="text-muted my-4">Khách hàng không cung cấp ảnh.</p>
                }
            </div>
        </div>

        <!-- Form Xử Lý Của Admin -->
        <div class="card shadow-sm border-0 border-top border-4 border-warning">
            <div class="card-body">
                <h5 class="mb-3">Quyết định xử lý</h5>
                <form asp-action="UpdateStatus" method="post">
                    <input type="hidden" name="id" value="@Model.IDYCTH" />
                    <div class="mb-3">
                        <label class="form-label">Cập nhật trạng thái hiện tại:</label>
                        <select name="status" class="form-select form-select-lg">
                            <option value="Đang xử lý" selected="@(Model.TRANGTHAI == "Đang xử lý")">⏳ Đang xử lý</option>
                            <option value="Đã duyệt" selected="@(Model.TRANGTHAI == "Đã duyệt")">✅ Chấp nhận trả hàng (Đã duyệt)</option>
                            <option value="Từ chối" selected="@(Model.TRANGTHAI == "Từ chối")">❌ Từ chối yêu cầu</option>
                        </select>
                    </div>
                    <button type="submit" class="btn btn-warning w-100 fw-bold">LƯU TRẠNG THÁI</button>
                </form>
            </div>
        </div>
    </div>
</div>