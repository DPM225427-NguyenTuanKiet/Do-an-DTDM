@model List<CarShop.Models.YeuCauTraHang>
@{
    ViewData["Title"] = "Quản lý yêu cầu trả hàng";
    Layout = "_AdminLayout";
    var donHangs = ViewBag.DonHangs as List<CarShop.Models.DonHang>;
    var khachHangs = ViewBag.KhachHangs as List<CarShop.Models.KhachHang>;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-undo-alt me-2"></i>Yêu cầu trả hàng</h2>
    <a asp-action="Create" class="btn btn-orange"><i class="fas fa-plus"></i> Thêm yêu cầu</a>
</div>

<div class="row mb-3">
    <div class="col-md-4">
        <form method="get" asp-action="Index" class="search-bar">
            <i class="fas fa-search"></i>
            <input type="text" name="search" placeholder="Tìm theo ID, đơn hàng, KH, trạng thái..." value="@ViewBag.Search" autocomplete="off" />
            <button type="submit"><i class="fas fa-arrow-right"></i></button>
        </form>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-custom table-hover align-middle">
        <thead>
            <tr>
                <th>ID YC</th>
                <th>Đơn hàng</th>
                <th>Khách hàng</th>
                <th>Ngày yêu cầu</th>
                <th>Lý do</th>
                <th>Trạng thái</th>
                <th>Hành động</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Any())
            {
                foreach (var item in Model)
                {
                    var dh = donHangs?.FirstOrDefault(d => d.IDDH == item.IDDH);
                    var kh = khachHangs?.FirstOrDefault(k => k.IDKH == item.IDKH);
                    <tr>
                        <td>@item.IDYCTH</td>
                        <td>@(dh != null ? $"#{dh.IDDH}" : "N/A")</td>
                        <td>@(kh?.HOTEN ?? "N/A")</td>
                        <td>@(item.NGAYYEUCAU?.ToString("dd/MM/yyyy HH:mm") ?? "")</td>
                        <td>@(item.LYDO ?? "")</td>
                        <td>
                            @if (item.TRANGTHAI == "Đã xử lý")
                            {
                                <span class="badge bg-success">Đã xử lý</span>
                            }
                            else if (item.TRANGTHAI == "Đang xử lý")
                            {
                                <span class="badge bg-warning">Đang xử lý</span>
                            }
                            else if (item.TRANGTHAI == "Đã từ chối")
                            {
                                <span class="badge bg-danger">Đã từ chối</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">@item.TRANGTHAI</span>
                            }
                        </td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.IDYCTH" class="btn btn-sm btn-info"><i class="fas fa-eye"></i></a>
                            <a asp-action="Edit" asp-route-id="@item.IDYCTH" class="btn btn-sm btn-warning"><i class="fas fa-edit"></i></a>
                            <a asp-action="Delete" asp-route-id="@item.IDYCTH" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="7" class="text-center">Không có dữ liệu</td></tr>
            }
        </tbody>
    </table>
</div>

@if (ViewBag.TotalPages > 1)
{
    <nav class="mt-4">
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.Page ? "active" : "")">
                    <a class="page-link" href="@Url.Action("Index", new { search = ViewBag.Search, page = i, pageSize = ViewBag.PageSize })">@i</a>
                </li>
            }
        </ul>
    </nav>
}