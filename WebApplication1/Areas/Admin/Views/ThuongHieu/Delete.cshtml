@model CarShop.Models.ThuongHieu
@{
    ViewData["Title"] = "Xóa thương hiệu";
    Layout = "_AdminLayout";
}

<div class="card shadow-sm">
    <div class="card-header bg-danger text-white">
        <h4><i class="fas fa-exclamation-triangle"></i> Xác nhận xóa thương hiệu</h4>
    </div>
    <div class="card-body">
        <div class="alert alert-warning">
            <i class="fas fa-info-circle"></i> Bạn có chắc chắn muốn xóa thương hiệu <strong>@Model.TENTHUONGHIEU</strong>? Hành động không thể hoàn tác.
        </div>
        <dl class="row">
            <dt class="col-sm-3">ID TH</dt>
            <dd class="col-sm-9">@Model.IDTH</dd>
            <dt class="col-sm-3">Tên thương hiệu</dt>
            <dd class="col-sm-9">@Model.TENTHUONGHIEU</dd>
            <dt class="col-sm-3">Quốc gia</dt>
            <dd class="col-sm-9">@(Model.QUOCGIA ?? "")</dd>
        </dl>
        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="IDTH" />
            <button type="submit" class="btn btn-danger"><i class="fas fa-trash-alt"></i> Xóa</button>
            <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Quay lại</a>
        </form>
    </div>
</div>