@model CarShop.Models.DonHang
@{
    ViewData["Title"] = "Chi tiết đơn hàng";
    Layout = "_AdminLayout";
    var khachHang = ViewBag.KhachHang as CarShop.Models.KhachHang;
    var products = ViewBag.Products as Dictionary<int, CarShop.Models.SanPham>;
}

<div class="card shadow-sm mb-4">
    <div class="card-header bg-primary text-white">
        <h4><i class="fas fa-info-circle"></i> Thông tin đơn hàng #@Model.IDDH</h4>
    </div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">ID Đơn hàng</dt>
            <dd class="col-sm-9">@Model.IDDH</dd>
            <dt class="col-sm-3">Khách hàng</dt>
            <dd class="col-sm-9">@(khachHang?.HOTEN ?? "N/A") (ID: @Model.IDKH)</dd>
            <dt class="col-sm-3">Ngày đặt</dt>
            <dd class="col-sm-9">@Model.NGAYDAT.ToString("dd/MM/yyyy HH:mm")</dd>
            <dt class="col-sm-3">Tổng tiền</dt>
            <dd class="col-sm-9">@Model.TONGTIEN.ToString("N0") VNĐ</dd>
            <dt class="col-sm-3">Trạng thái</dt>
            <dd class="col-sm-9">
                <form asp-action="UpdateStatus" method="post" style="display:inline">
                    <input type="hidden" name="id" value="@Model.IDDH" />
                    <select name="status" class="form-select form-select-sm" style="width:150px; display:inline-block">
                        <option value="Chờ xử lý" selected="@(Model.TRANGTHAI == "Chờ xử lý")">Chờ xử lý</option>
                        <option value="Đang giao" selected="@(Model.TRANGTHAI == "Đang giao")">Đang giao</option>
                        <option value="Đã giao" selected="@(Model.TRANGTHAI == "Đã giao")">Đã giao</option>
                        <option value="Đã hủy" selected="@(Model.TRANGTHAI == "Đã hủy")">Đã hủy</option>
                    </select>
                    <button type="submit" class="btn btn-sm btn-primary">Cập nhật</button>
                </form>
            </dd>
            <dt class="col-sm-3">Địa chỉ giao</dt>
            <dd class="col-sm-9">@Model.DIACHIGIAO</dd>
        </dl>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header bg-secondary text-white">
        <h5><i class="fas fa-boxes"></i> Chi tiết sản phẩm</h5>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th>ID SP</th>
                        <th>Tên sản phẩm</th>
                        <th>Số lượng</th>
                        <th>Đơn giá</th>
                        <th>Thành tiền</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.CHITIET)
                    {
                        var product = products != null && products.ContainsKey(item.IDSP) ? products[item.IDSP] : null;
                        <tr>
                            <td>@item.IDSP</td>
                            <td>@(product?.TENSP ?? "N/A")</td>
                            <td>@item.SOLUONG</td>
                            <td>@item.DONGIA.ToString("N0") VNĐ</td>
                            <td>@((item.SOLUONG * item.DONGIA).ToString("N0")) VNĐ</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr class="table-active">
                        <td colspan="4" class="text-end fw-bold">Tổng cộng:</td>
                        <td class="fw-bold">@Model.TONGTIEN.ToString("N0") VNĐ</td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Quay lại</a>
</div>