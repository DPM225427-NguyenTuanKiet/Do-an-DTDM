@model List<CarShop.Models.DonHang>
@{
    ViewData["Title"] = "Quản lý đơn hàng";
    Layout = "_AdminLayout";
    var khachHangs = ViewBag.KhachHangs as List<CarShop.Models.KhachHang>;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-shopping-cart me-2"></i>Quản lý đơn hàng</h2>
</div>

<div class="row mb-3">
    <div class="col-md-4">
        <form method="get" asp-action="Index" class="search-bar">
            <i class="fas fa-search"></i>
            <input type="text" name="search" placeholder="Tìm theo ID đơn hoặc ID KH..." value="@ViewBag.Search" autocomplete="off">
            <button type="submit"><i class="fas fa-arrow-right"></i></button>
        </form>
    </div>
    <div class="col-md-3">
        <select name="trangThai" class="form-select" onchange="this.form.submit()" form="filterForm">
            <option value="all" selected="@(ViewBag.TrangThai == null || ViewBag.TrangThai == "all")">Tất cả trạng thái</option>
            <option value="Chờ xử lý" selected="@(ViewBag.TrangThai == "Chờ xử lý")">Chờ xử lý</option>
            <option value="Đang giao" selected="@(ViewBag.TrangThai == "Đang giao")">Đang giao</option>
            <option value="Đã giao" selected="@(ViewBag.TrangThai == "Đã giao")">Đã giao</option>
            <option value="Đã hủy" selected="@(ViewBag.TrangThai == "Đã hủy")">Đã hủy</option>
        </select>
    </div>
</div>
<form id="filterForm" method="get" asp-action="Index">
    <input type="hidden" name="search" value="@ViewBag.Search" />
    <input type="hidden" name="trangThai" id="hdTrangThai" />
</form>

<div class="table-responsive">
    <table class="table table-custom table-hover align-middle">
        <thead>
            <tr>
                <th>ID ĐH</th>
                <th>Khách hàng</th>
                <th>Ngày đặt</th>
                <th>Tổng tiền</th>
                <th>Trạng thái</th>
                <th>Địa chỉ giao</th>
                <th>Hành động</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Any())
            {
                foreach (var item in Model)
                {
                    var kh = khachHangs?.FirstOrDefault(k => k.IDKH == item.IDKH);
                    <tr>
                        <td>@item.IDDH</td>
                        <td>@(kh?.HOTEN ?? "N/A") (@item.IDKH)</td>
                        <td>@item.NGAYDAT.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@item.TONGTIEN.ToString("N0") VNĐ</td>
                        <td>
                            @if (item.TRANGTHAI == "Chờ xử lý")
                            {
                                <span class="badge bg-warning text-dark">Chờ xử lý</span>
                            }
                            else if (item.TRANGTHAI == "Đang giao")
                            {
                                <span class="badge bg-info text-dark">Đang giao</span>
                            }
                            else if (item.TRANGTHAI == "Đã giao" || item.TRANGTHAI == "Đã thanh toán")
                            {
                                <span class="badge bg-success">@item.TRANGTHAI</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">@item.TRANGTHAI</span>
                            }
                        </td>
                        <td>@item.DIACHIGIAO</td>
                        <td>
                            @* Điều kiện ẩn nút duyệt khi đơn đã duyệt, hoặc trạng thái là Đã giao / Đã thanh toán *@
                            @if (!item.DA_DUYET && item.TRANGTHAI != "Đã giao" && item.TRANGTHAI != "Đã thanh toán" && item.TRANGTHAI != "Đã hủy")
                            {
                                <form asp-action="Duyet" method="post" style="display:inline">
                                    <input type="hidden" name="id" value="@item.IDDH" />
                                    <button type="submit" class="btn btn-sm btn-success" title="Duyệt đơn">
                                        <i class="fas fa-check"></i> Duyệt
                                    </button>
                                </form>
                            }
                            else if (item.DA_DUYET)
                            {
                                <span class="badge bg-success me-1">Đã duyệt</span>
                            }
                            
                            <a asp-action="Details" asp-route-id="@item.IDDH" class="btn btn-sm btn-info text-white" title="Chi tiết">
                                <i class="fas fa-eye"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.IDDH" class="btn btn-sm btn-danger" title="Xóa">
                                <i class="fas fa-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="7" class="text-center">Không có đơn hàng nào</td></tr>
            }
        </tbody>
    </table>
</div>

@if (ViewBag.TotalPages > 1)
{
    <nav class="mt-4">
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.Page ? "active" : "")">
                    <a class="page-link" href="@Url.Action("Index", new { search = ViewBag.Search, trangThai = ViewBag.TrangThai, page = i, pageSize = ViewBag.PageSize })">@i</a>
                </li>
            }
        </ul>
    </nav>
}

@section Scripts {
    <script>
        document.querySelector('select[name="trangThai"]').addEventListener('change', function() {
            document.getElementById('hdTrangThai').value = this.value;
            document.getElementById('filterForm').submit();
        });
    </script>
}