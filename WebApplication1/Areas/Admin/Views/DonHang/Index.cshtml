@model List<CarShop.Models.DonHang>
@{
    ViewData["Title"] = "Quản lý đơn hàng";
    Layout = "_AdminLayout";
    var khachHangs = ViewBag.KhachHangs as List<CarShop.Models.KhachHang>;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold text-dark mb-0">
        <i class="fas fa-shopping-cart text-primary me-2"></i> @ViewData["Title"]
    </h3>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body p-3">
        <form method="get" asp-action="Index" class="row g-3 align-items-center m-0">
            <div class="col-md-5 ps-0">
                <div class="search-bar w-100">
                    <i class="fas fa-search ms-2"></i>
                    <input type="text" name="search" class="form-control border-0 bg-transparent shadow-none"
                           placeholder="Tìm theo ID đơn hoặc ID KH..." value="@ViewBag.Search" autocomplete="off">
                    <button type="submit" class="btn"><i class="fas fa-arrow-right"></i></button>
                </div>
            </div>
            <div class="col-md-3">
                <select name="trangThai" class="form-select rounded-pill border-0 bg-light px-3" onchange="this.form.submit()">
                    <option value="all" selected="@(ViewBag.TrangThai == null || ViewBag.TrangThai == "all")">Tất cả trạng thái</option>
                    <option value="Chờ xử lý" selected="@(ViewBag.TrangThai == "Chờ xử lý")">Chờ xử lý</option>
                    <option value="Đang giao" selected="@(ViewBag.TrangThai == "Đang giao")">Đang giao</option>
                    <option value="Đã giao" selected="@(ViewBag.TrangThai == "Đã giao")">Đã giao</option>
                    <option value="Đã hủy" selected="@(ViewBag.TrangThai == "Đã hủy")">Đã hủy</option>
                </select>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-custom table-hover align-middle mb-0">
                <thead class="table-light text-muted">
                    <tr>
                        <th class="ps-4">ID ĐH</th>
                        <th>Khách hàng</th>
                        <th>Ngày đặt</th>
                        <th>Tổng tiền</th>
                        <th>Trạng thái</th>
                        <th>Địa chỉ giao</th>
                        <th class="text-center pe-4">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            var kh = khachHangs?.FirstOrDefault(k => k.IDKH == item.IDKH);
                            <tr>
                                <td class="ps-4 fw-bold text-dark">#@item.IDDH</td>
                                <td class="fw-medium text-primary">
                                    @(kh?.HOTEN ?? "N/A")
                                    <br><small class="text-muted">ID: @item.IDKH</small>
                                </td>
                                <td>@item.NGAYDAT.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="fw-bold text-danger">@item.TONGTIEN.ToString("N0") đ</td>
                                <td>
                                    @if (item.TRANGTHAI == "Chờ xử lý")
                                    {
                                        <span class="badge bg-warning text-dark rounded-pill px-3">Chờ xử lý</span>
                                    }
                                    else if (item.TRANGTHAI == "Đang giao")
                                    {
                                        <span class="badge bg-info text-dark rounded-pill px-3">Đang giao</span>
                                    }
                                    else if (item.TRANGTHAI == "Đã giao" || item.TRANGTHAI == "Đã thanh toán")
                                    {
                                        <span class="badge bg-success rounded-pill px-3">@item.TRANGTHAI</span>
                                    }
                                    else if (item.TRANGTHAI == "Đã hủy")
                                    {
                                        <span class="badge bg-danger rounded-pill px-3">Đã hủy</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary rounded-pill px-3">@item.TRANGTHAI</span>
                                    }
                                </td>
                                <td>
                                    <span class="d-inline-block text-truncate" style="max-width: 180px;" title="@item.DIACHIGIAO">
                                        @item.DIACHIGIAO
                                    </span>
                                </td>
                                <td class="text-center pe-4">
                                    <div class="d-flex justify-content-center align-items-center gap-2">
                                        @* Xử lý hiển thị nút Duyệt *@
                                        @if (!item.DA_DUYET && item.TRANGTHAI != "Đã giao" && item.TRANGTHAI != "Đã thanh toán" && item.TRANGTHAI != "Đã hủy")
                                        {
                                            <form asp-action="Duyet" method="post" class="m-0">
                                                <input type="hidden" name="id" value="@item.IDDH" />
                                                <button type="submit" class="btn btn-success btn-sm rounded-pill px-3 shadow-sm" title="Duyệt đơn">
                                                    <i class="fas fa-check me-1"></i> Duyệt
                                                </button>
                                            </form>
                                        }
                                        else if (item.DA_DUYET)
                                        {
                                            <span class="badge border border-success text-success px-2 py-1"><i class="fas fa-check-circle me-1"></i>Đã duyệt</span>
                                        }
                                        
                                        @* Cụm nút Xem chi tiết / Xóa *@
                                        <div class="btn-group shadow-sm">
                                            <a asp-action="Details" asp-route-id="@item.IDDH" class="btn btn-outline-info btn-sm" title="Chi tiết">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.IDDH" class="btn btn-outline-danger btn-sm" title="Xóa" onclick="return confirm('Bạn có chắc chắn muốn xóa đơn hàng này?');">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">
                                <i class="fas fa-box-open fs-1 mb-3 opacity-50"></i>
                                <p class="mb-0">Không có đơn hàng nào.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (ViewBag.TotalPages != null && ViewBag.TotalPages > 1)
{
    <nav class="mt-4">
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.Page ? "active" : "")">
                    <a class="page-link shadow-sm mx-1 rounded-3" href="@Url.Action("Index", new { search = ViewBag.Search, trangThai = ViewBag.TrangThai, page = i, pageSize = ViewBag.PageSize })">@i</a>
                </li>
            }
        </ul>
    </nav>
}