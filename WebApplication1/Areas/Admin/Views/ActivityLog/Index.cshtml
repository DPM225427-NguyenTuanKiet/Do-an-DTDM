@model List<CarShop.Models.ActivityLog>
@{
    ViewData["Title"] = "Nhật ký hoạt động";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-history me-2"></i>Nhật ký hoạt động</h2>
    <div>
        <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#deleteOldModal">
            <i class="fas fa-trash-alt"></i> Xóa log cũ
        </button>
    </div>
</div>

<!-- Tìm kiếm và lọc -->
<div class="row mb-3">
    <div class="col-md-4">
        <form method="get" asp-action="Index" class="search-bar">
            <i class="fas fa-search"></i>
            <input type="text" name="search" placeholder="Tìm theo ID, hành động, chi tiết..." value="@ViewBag.Search" autocomplete="off">
            <button type="submit"><i class="fas fa-arrow-right"></i></button>
        </form>
    </div>
</div>

<!-- Bảng danh sách -->
<div class="table-responsive">
    <form id="deleteMultipleForm" asp-action="DeleteMultiple" method="post">
        <table class="table table-admin table-hover align-middle">
            <thead>
                <tr>
                    <th style="width: 40px"><input type="checkbox" id="selectAll"></th>
                    <th>ID</th>
                    <th>ID TK</th>
                    <th>Thời gian</th>
                    <th>Hành động</th>
                    <th>Chi tiết</th>
                    <th>IP</th>
                    <th>Hành động</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td><input type="checkbox" name="ids" value="@item.IDLOG" class="rowCheckbox"></td>
                            <td>@item.IDLOG</td>
                            <td>@item.IDTK</td>
                            <td>@(item.THOIGIAN?.ToString("dd/MM/yyyy HH:mm:ss") ?? "")</td>
                            <td>@item.HANHDONG</td>
                            <td>@item.CHITIET</td>
                            <td>@item.IP</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@item.IDLOG" class="btn btn-sm btn-info">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.IDLOG" class="btn btn-sm btn-danger" onclick="return confirm('Xóa log này?')">
                                    <i class="fas fa-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="text-center">Không có dữ liệu</td>
                    </tr>
                }
            </tbody>
        </table>
        <button type="submit" class="btn btn-danger" id="deleteSelectedBtn" disabled>
            <i class="fas fa-trash-alt"></i> Xóa các mục đã chọn
        </button>
    </form>
</div>

<!-- Phân trang -->
@if (ViewBag.TotalPages > 1)
{
    <nav class="mt-4">
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.Page ? "active" : "")">
                    <a class="page-link" href="@Url.Action("Index", new { search = ViewBag.Search, page = i, pageSize = ViewBag.PageSize })">@i</a>
                </li>
            }
        </ul>
    </nav>
}

<!-- Modal xóa log cũ -->
<div class="modal fade" id="deleteOldModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="DeleteOldLogs" method="post">
                <div class="modal-header">
                    <h5 class="modal-title">Xóa log cũ</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Xóa log trước ngày:</label>
                        <input type="date" name="beforeDate" class="form-control" required value="@DateTime.Now.AddMonths(-1).ToString("yyyy-MM-dd")">
                    </div>
                    <div class="alert alert-warning">
                        <i class="fas fa-exclamation-triangle"></i> Hành động này không thể hoàn tác.
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-danger">Xóa</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/admin.js"></script>
}