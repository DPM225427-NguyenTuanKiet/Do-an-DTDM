@model CarShop.Models.BaoHanh
@{
    ViewData["Title"] = "Sửa bảo hành";
    Layout = "_AdminLayout";
    var sanPhams = ViewBag.SanPhams as List<CarShop.Models.SanPham>;
    var khachHangs = ViewBag.KhachHangs as List<CarShop.Models.KhachHang>;
    var donHangs = ViewBag.DonHangs as List<CarShop.Models.DonHang>;
}

<div class="card shadow-sm">
    <div class="card-header bg-warning text-dark">
        <h4><i class="fas fa-edit"></i> Sửa bảo hành #@Model.IDBH</h4>
    </div>
    <div class="card-body">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="IDBH" />
            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label asp-for="IDSP" class="form-label">Sản phẩm</label>
                        <select asp-for="IDSP" class="form-select" required>
                            <option value="">-- Chọn sản phẩm --</option>
                            @foreach (var sp in sanPhams)
                            {
                                <option value="@sp.IDSP" selected="@(sp.IDSP == Model.IDSP)">@sp.TENSP</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label asp-for="IDKH" class="form-label">Khách hàng</label>
                        <select asp-for="IDKH" class="form-select" required>
                            <option value="">-- Chọn khách hàng --</option>
                            @foreach (var kh in khachHangs)
                            {
                                <option value="@kh.IDKH" selected="@(kh.IDKH == Model.IDKH)">@kh.HOTEN</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label asp-for="IDDH" class="form-label">Đơn hàng</label>
                        <select asp-for="IDDH" class="form-select" required>
                            <option value="">-- Chọn đơn hàng --</option>
                            @foreach (var dh in donHangs)
                            {
                                <option value="@dh.IDDH" selected="@(dh.IDDH == Model.IDDH)">#@dh.IDDH</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label asp-for="NGAYBATDAU" class="form-label">Ngày bắt đầu</label>
                        <input asp-for="NGAYBATDAU" type="date" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label asp-for="NGAYKETTHUC" class="form-label">Ngày kết thúc</label>
                        <input asp-for="NGAYKETTHUC" type="date" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label asp-for="TRANGTHAI" class="form-label">Trạng thái</label>
                        <select asp-for="TRANGTHAI" class="form-select">
                            <option value="Đang bảo hành" selected="@(Model.TRANGTHAI == "Đang bảo hành")">Đang bảo hành</option>
                            <option value="Đã kết thúc" selected="@(Model.TRANGTHAI == "Đã kết thúc")">Đã kết thúc</option>
                        </select>
                    </div>
                </div>
            </div>
            <div class="mt-3">
                <button type="submit" class="btn btn-orange"><i class="fas fa-save"></i> Lưu thay đổi</button>
                <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-times"></i> Hủy</a>
            </div>
        </form>
    </div>
</div>
