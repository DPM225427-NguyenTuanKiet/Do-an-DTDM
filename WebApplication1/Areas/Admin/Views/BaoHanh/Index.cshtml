@model List<CarShop.Models.BaoHanh>
@{
    ViewData["Title"] = "Quản lý bảo hành";
    Layout = "_AdminLayout";
    var sanPhams = ViewBag.SanPhams as List<CarShop.Models.SanPham>;
    var khachHangs = ViewBag.KhachHangs as List<CarShop.Models.KhachHang>;
    var donHangs = ViewBag.DonHangs as List<CarShop.Models.DonHang>;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold text-dark mb-0">
        <i class="fas fa-shield-alt text-primary me-2"></i> @ViewData["Title"]
    </h3>
    <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm">
        <i class="fas fa-plus me-1"></i> Thêm bảo hành
    </a>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body p-3">
        <form method="get" asp-action="Index" class="row g-3 align-items-center m-0">
            <div class="col-md-5 ps-0">
                <div class="search-bar w-100">
                    <i class="fas fa-search ms-2"></i>
                    <input type="text" name="search" class="form-control border-0 bg-transparent shadow-none"
                           placeholder="Tìm theo ID, Tên SP, Tên KH..." value="@ViewBag.Search" autocomplete="off">
                    <button type="submit" class="btn"><i class="fas fa-arrow-right"></i></button>
                </div>
            </div>
            <div class="col-md-3">
                <select name="trangThai" class="form-select rounded-pill border-0 bg-light px-3" onchange="this.form.submit()">
                    <option value="all" selected="@(ViewBag.TrangThai == null || ViewBag.TrangThai == "all")">Tất cả trạng thái</option>
                    <option value="Đang bảo hành" selected="@(ViewBag.TrangThai == "Đang bảo hành")">Đang bảo hành</option>
                    <option value="Đã kết thúc" selected="@(ViewBag.TrangThai == "Đã kết thúc")">Đã kết thúc</option>
                </select>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-custom table-hover align-middle mb-0">
                <thead class="table-light text-muted">
                    <tr>
                        <th class="ps-4">ID BH</th>
                        <th>Sản phẩm</th>
                        <th>Khách hàng</th>
                        <th>Đơn hàng</th>
                        <th>Ngày bắt đầu</th>
                        <th>Ngày kết thúc</th>
                        <th>Trạng thái</th>
                        <th class="text-center pe-4">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            var sanPham = sanPhams?.FirstOrDefault(s => s.IDSP == item.IDSP);
                            var khachHang = khachHangs?.FirstOrDefault(k => k.IDKH == item.IDKH);
                            var donHang = donHangs?.FirstOrDefault(d => d.IDDH == item.IDDH);

                            <tr>
                                <td class="ps-4 fw-bold text-dark">@item.IDBH</td>
                                <td class="fw-medium text-primary">@(sanPham?.TENSP ?? "N/A")</td>
                                <td>@(khachHang?.HOTEN ?? "N/A")</td>
                                <td>
                                    <span class="badge bg-light text-dark border">#@item.IDDH</span>
                                </td>
                                <td>@(item.NGAYBATDAU?.ToString("dd/MM/yyyy") ?? "")</td>
                                <td>@(item.NGAYKETTHUC?.ToString("dd/MM/yyyy") ?? "")</td>
                                <td>
                                    @if (item.TRANGTHAI == "Đang bảo hành")
                                    {
                                        <span class="badge bg-success rounded-pill px-3">Đang bảo hành</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary rounded-pill px-3">Đã kết thúc</span>
                                    }
                                </td>
                                <td class="text-center pe-4">
                                    <div class="btn-group shadow-sm">
                                        <a asp-action="Details" asp-route-id="@item.IDBH" class="btn btn-outline-info btn-sm" title="Xem chi tiết">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.IDBH" class="btn btn-outline-warning btn-sm" title="Sửa">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.IDBH" class="btn btn-outline-danger btn-sm" onclick="return confirm('Xóa bảo hành này?')" title="Xóa">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center py-5 text-muted">
                                <i class="fas fa-shield-alt fs-1 mb-3 opacity-50"></i>
                                <p class="mb-0">Không có dữ liệu bảo hành.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (ViewBag.TotalPages != null && ViewBag.TotalPages > 1)
{
    <nav class="mt-4">
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.Page ? "active" : "")">
                    <a class="page-link shadow-sm mx-1 rounded-3" href="@Url.Action("Index", new { search = ViewBag.Search, trangThai = ViewBag.TrangThai, page = i, pageSize = ViewBag.PageSize })">@i</a>
                </li>
            }
        </ul>
    </nav>
}