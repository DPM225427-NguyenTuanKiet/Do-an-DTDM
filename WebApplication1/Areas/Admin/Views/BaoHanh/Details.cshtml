@model CarShop.Models.BaoHanh
@{
    ViewData["Title"] = "Chi tiết bảo hành";
    Layout = "_AdminLayout";
    var sanPham = ViewBag.SanPham as CarShop.Models.SanPham;
    var khachHang = ViewBag.KhachHang as CarShop.Models.KhachHang;
    var donHang = ViewBag.DonHang as CarShop.Models.DonHang;
}

<div class="card shadow-sm mb-4">
    <div class="card-header bg-primary text-white">
        <h4><i class="fas fa-info-circle"></i> Thông tin bảo hành</h4>
    </div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">ID BH</dt>
            <dd class="col-sm-9">@Model.IDBH</dd>
            <dt class="col-sm-3">Sản phẩm</dt>
            <dd class="col-sm-9">@(sanPham?.TENSP ?? "N/A")</dd>
            <dt class="col-sm-3">Khách hàng</dt>
            <dd class="col-sm-9">@(khachHang?.HOTEN ?? "N/A")</dd>
            <dt class="col-sm-3">Đơn hàng</dt>
            <dd class="col-sm-9">#@Model.IDDH</dd>
            <dt class="col-sm-3">Ngày bắt đầu</dt>
            <dd class="col-sm-9">@(Model.NGAYBATDAU?.ToString("dd/MM/yyyy"))</dd>
            <dt class="col-sm-3">Ngày kết thúc</dt>
            <dd class="col-sm-9">@(Model.NGAYKETTHUC?.ToString("dd/MM/yyyy"))</dd>
            <dt class="col-sm-3">Trạng thái</dt>
            <dd class="col-sm-9">
                @if (Model.TRANGTHAI == "Đang bảo hành")
                {
                    <span class="badge bg-warning">Đang bảo hành</span>
                }
                else
                {
                    <span class="badge bg-secondary">Đã kết thúc</span>
                }
            </dd>
        </dl>
    </div>
</div>

<!-- Lịch sử bảo hành -->
<div class="card shadow-sm">
    <div class="card-header bg-secondary text-white d-flex justify-content-between align-items-center">
        <h5><i class="fas fa-history"></i> Lịch sử bảo hành</h5>
        <button type="button" class="btn btn-sm btn-light" data-bs-toggle="modal" data-bs-target="#addHistoryModal">
            <i class="fas fa-plus"></i> Thêm
        </button>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Ngày tiếp nhận</th>
                        <th>Ngày trả</th>
                        <th>Nội dung</th>
                        <th>Tình trạng</th>
                        <th>Chi phí</th>
                        <th>Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.LICHSU.Any())
                    {
                        foreach (var ls in Model.LICHSU.OrderByDescending(x => x.NGAYTIEPNHAN))
                        {
                            <tr>
                                <td>@ls.IDLS</td>
                                <td>@(ls.NGAYTIEPNHAN?.ToString("dd/MM/yyyy HH:mm") ?? "")</td>
                                <td>@(ls.NGAYTRA?.ToString("dd/MM/yyyy HH:mm") ?? "")</td>
                                <td>@ls.NOIDUNG</td>
                                <td>@ls.TINHTRANG</td>
                                <td>@(ls.CHIPHI?.ToString("N0") ?? "0")</td>
                                <td>
                                    <button class="btn btn-sm btn-warning" onclick="editHistory(@ls.IDLS)"><i class="fas fa-edit"></i></button>
                                    <button class="btn btn-sm btn-danger" onclick="deleteHistory(@ls.IDLS)"><i class="fas fa-trash"></i></button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="7" class="text-center">Chưa có lịch sử</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Quay lại</a>
</div>

<!-- Modal thêm lịch sử -->
<div class="modal fade" id="addHistoryModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="AddHistory" method="post">
                <input type="hidden" name="id" value="@Model.IDBH" />
                <div class="modal-header">
                    <h5 class="modal-title">Thêm lịch sử bảo hành</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Ngày tiếp nhận</label>
                        <input type="datetime-local" name="history.NGAYTIEPNHAN" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Ngày trả</label>
                        <input type="datetime-local" name="history.NGAYTRA" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Nội dung</label>
                        <textarea name="history.NOIDUNG" class="form-control" rows="3"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Tình trạng</label>
                        <input type="text" name="history.TINHTRANG" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Chi phí</label>
                        <input type="number" name="history.CHIPHI" class="form-control" step="1000" value="0" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-orange">Thêm</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function editHistory(id) {
            // Có thể dùng modal hoặc chuyển trang
            alert("Tính năng sửa lịch sử: bạn có thể dùng form riêng hoặc modal. ID: " + id);
        }
        function deleteHistory(id) {
            if (confirm('Xóa lịch sử này?')) {
                // Gửi POST đến DeleteHistory
                var form = document.createElement('form');
                form.method = 'post';
                form.action = '@Url.Action("DeleteHistory", new { id = Model.IDBH })';
                var input = document.createElement('input');
                input.type = 'hidden';
                input.name = 'historyId';
                input.value = id;
                form.appendChild(input);
                document.body.appendChild(form);
                form.submit();
            }
        }
    </script>
}