@model CarShop.Models.ThuocTinh
@{
    ViewData["Title"] = "Xóa thuộc tính";
    Layout = "_AdminLayout";
}

<div class="card shadow-sm">
    <div class="card-header bg-danger text-white">
        <h4><i class="fas fa-exclamation-triangle"></i> Xác nhận xóa thuộc tính</h4>
    </div>
    <div class="card-body">
        <div class="alert alert-warning">
            <i class="fas fa-info-circle"></i> Bạn có chắc chắn muốn xóa thuộc tính <strong>@Model.TENTHUOCTINH</strong>? Hành động không thể hoàn tác.
        </div>
        <dl class="row">
            <dt class="col-sm-3">ID TT</dt>
            <dd class="col-sm-9">@Model.IDTT</dd>
            <dt class="col-sm-3">Tên thuộc tính</dt>
            <dd class="col-sm-9">@Model.TENTHUOCTINH</dd>
        </dl>
        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="IDTT" />
            <button type="submit" class="btn btn-danger"><i class="fas fa-trash-alt"></i> Xóa</button>
            <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Quay lại</a>
        </form>
    </div>
</div>