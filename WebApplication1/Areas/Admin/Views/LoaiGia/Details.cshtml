@model CarShop.Models.LoaiGia
@{
    ViewData["Title"] = "Chi tiết loại giá";
    Layout = "_AdminLayout";
}

<div class="card shadow-sm">
    <div class="card-header bg-primary text-white">
        <h4><i class="fas fa-info-circle"></i> Chi tiết loại giá #@Model.IDLG</h4>
    </div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">ID</dt>
            <dd class="col-sm-9">@Model.IDLG</dd>
            <dt class="col-sm-3">Tên loại giá</dt>
            <dd class="col-sm-9">@Model.TENLOAI</dd>
            <dt class="col-sm-3">Điểm thưởng</dt>
            <dd class="col-sm-9">@Model.DIEMTHUONG</dd>
            <dt class="col-sm-3">Giảm giá (%)</dt>
            <dd class="col-sm-9">@Model.GIAMGIA</dd>
            <dt class="col-sm-3">Điểm tối thiểu</dt>
            <dd class="col-sm-9">@Model.DIEM_TOITHIEU</dd>
        </dl>
    </div>
    <div class="card-footer">
        <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Quay lại</a>
        <a asp-action="Edit" asp-route-id="@Model.IDLG" class="btn btn-warning"><i class="fas fa-edit"></i> Sửa</a>
        <a asp-action="Delete" asp-route-id="@Model.IDLG" class="btn btn-danger"><i class="fas fa-trash"></i> Xóa</a>
    </div>
</div>