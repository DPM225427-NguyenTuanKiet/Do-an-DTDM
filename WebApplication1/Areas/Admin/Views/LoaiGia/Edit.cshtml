@model CarShop.Models.LoaiGia
@{
    ViewData["Title"] = "Sửa loại giá";
    Layout = "_AdminLayout";
}

<div class="card shadow-sm">
    <div class="card-header bg-warning text-dark">
        <h4><i class="fas fa-edit"></i> Sửa loại giá #@Model.IDLG</h4>
    </div>
    <div class="card-body">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="IDLG" />
            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label asp-for="TENLOAI" class="form-label">Tên loại giá</label>
                        <input asp-for="TENLOAI" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label asp-for="DIEMTHUONG" class="form-label">Điểm thưởng</label>
                        <input asp-for="DIEMTHUONG" class="form-control" type="number" required />
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label asp-for="GIAMGIA" class="form-label">Giảm giá (%)</label>
                        <input asp-for="GIAMGIA" class="form-control" type="number" step="0.01" required />
                    </div>
                    <div class="mb-3">
                        <label asp-for="DIEM_TOITHIEU" class="form-label">Điểm tối thiểu</label>
                        <input asp-for="DIEM_TOITHIEU" class="form-control" type="number" required />
                    </div>
                </div>
            </div>
            <button type="submit" class="btn btn-orange"><i class="fas fa-save"></i> Lưu thay đổi</button>
            <a asp-action="Index" class="btn btn-secondary">Hủy</a>
        </form>
    </div>
</div>