@model CarShop.Models.SanPham
@{
    ViewData["Title"] = "Xóa sản phẩm";
    Layout = "_AdminLayout";
    var danhMuc = ViewBag.DanhMuc as CarShop.Models.DanhMuc;
    var thuongHieu = ViewBag.ThuongHieu as CarShop.Models.ThuongHieu;
}

<div class="card shadow-sm">
    <div class="card-header bg-danger text-white">
        <h4><i class="fas fa-exclamation-triangle"></i> Xác nhận xóa sản phẩm</h4>
    </div>
    <div class="card-body">
        <div class="alert alert-warning">
            <i class="fas fa-info-circle"></i> Bạn có chắc chắn muốn xóa sản phẩm <strong>@Model.TENSP</strong>? Hành động không thể hoàn tác.
        </div>
        <dl class="row">
            <dt class="col-sm-3">ID SP</dt>
            <dd class="col-sm-9">@Model.IDSP</dd>
            <dt class="col-sm-3">Tên sản phẩm</dt>
            <dd class="col-sm-9">@Model.TENSP</dd>
            <dt class="col-sm-3">Giá</dt>
            <dd class="col-sm-9">@Model.GIA.ToString("N0") VNĐ</dd>
            <dt class="col-sm-3">Danh mục</dt>
            <dd class="col-sm-9">@(danhMuc?.TENDANHMUC ?? "N/A")</dd>
            <dt class="col-sm-3">Thương hiệu</dt>
            <dd class="col-sm-9">@(thuongHieu?.TENTHUONGHIEU ?? "N/A")</dd>
        </dl>
        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="IDSP" />
            <button type="submit" class="btn btn-danger"><i class="fas fa-trash-alt"></i> Xóa</button>
            <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Quay lại</a>
        </form>
    </div>
</div>
