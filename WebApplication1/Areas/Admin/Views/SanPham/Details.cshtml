@model CarShop.Models.SanPham
@{
    ViewData["Title"] = "Chi tiết sản phẩm";
    Layout = "_AdminLayout";
    var danhMuc = ViewBag.DanhMuc as CarShop.Models.DanhMuc;
    var thuongHieu = ViewBag.ThuongHieu as CarShop.Models.ThuongHieu;
}

<div class="card shadow-sm">
    <div class="card-header bg-primary text-white">
        <h4><i class="fas fa-info-circle"></i> Chi tiết sản phẩm #@Model.IDSP</h4>
    </div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">ID SP</dt>
            <dd class="col-sm-9">@Model.IDSP</dd>
            <dt class="col-sm-3">Tên sản phẩm</dt>
            <dd class="col-sm-9">@Model.TENSP</dd>
            <dt class="col-sm-3">Giá</dt>
            <dd class="col-sm-9">@Model.GIA.ToString("N0") VNĐ</dd>
            <dt class="col-sm-3">Số lượng</dt>
            <dd class="col-sm-9">@Model.SOLUONG</dd>
            <dt class="col-sm-3">Mô tả</dt>
            <dd class="col-sm-9">@(Model.MOTA ?? "")</dd>
            <dt class="col-sm-3">Danh mục</dt>
            <dd class="col-sm-9">@(danhMuc?.TENDANHMUC ?? "N/A")</dd>
            <dt class="col-sm-3">Thương hiệu</dt>
            <dd class="col-sm-9">@(thuongHieu?.TENTHUONGHIEU ?? "N/A")</dd>
            <dt class="col-sm-3">Ngày tạo</dt>
            <dd class="col-sm-9">@Model.NGAYTAO.ToString("dd/MM/yyyy HH:mm")</dd>
            <dt class="col-sm-3">Trạng thái</dt>
            <dd class="col-sm-9">
                @if (Model.TRANGTHAI)
                {
                    <span class="badge bg-success">Đang bán</span>
                }
                else
                {
                    <span class="badge bg-secondary">Ngừng bán</span>
                }
            </dd>
            <dt class="col-sm-3">Tồn kho tối thiểu</dt>
            <dd class="col-sm-9">@Model.TONKHO_TOITHIEU</dd>
        </dl>
    </div>
    <div class="card-footer">
        <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Quay lại</a>
        <a asp-action="Edit" asp-route-id="@Model.IDSP" class="btn btn-warning"><i class="fas fa-edit"></i> Sửa</a>
        <a asp-action="Delete" asp-route-id="@Model.IDSP" class="btn btn-danger"><i class="fas fa-trash"></i> Xóa</a>
    </div>
</div>