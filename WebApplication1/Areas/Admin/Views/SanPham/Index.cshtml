@model List<CarShop.Models.SanPham>
@{
    ViewData["Title"] = "Quản lý sản phẩm";
    Layout = "_AdminLayout";
    var danhMucs = ViewBag.DanhMucs as List<CarShop.Models.DanhMuc>;
    var thuongHieus = ViewBag.ThuongHieus as List<CarShop.Models.ThuongHieu>;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-car me-2"></i>Quản lý sản phẩm</h2>
    <div>
        <a asp-action="ExportExcel" class="btn btn-success me-2"><i class="fas fa-file-excel"></i> Xuất Excel</a>
        <a asp-action="Create" class="btn btn-orange"><i class="fas fa-plus"></i> Thêm sản phẩm</a>
    </div>
</div>

<div class="row mb-3">
    <div class="col-md-4">
        <form method="get" asp-action="Index" class="search-bar" id="filterForm">
            <i class="fas fa-search"></i>
            <input type="text" name="search" placeholder="Tìm theo tên sản phẩm..." value="@ViewBag.Search" autocomplete="off">
            <button type="submit"><i class="fas fa-arrow-right"></i></button>
        </form>
    </div>
    <div class="col-md-3">
        <select name="category" class="form-select" onchange="this.form.submit()" form="filterForm">
            <option value="">-- Tất cả danh mục --</option>
            @foreach (var dm in danhMucs)
            {
                <option value="@dm.IDDM" selected="@(ViewBag.Category == dm.IDDM)">@dm.TENDANHMUC</option>
            }
        </select>
    </div>
    <div class="col-md-3">
        <select name="brand" class="form-select" onchange="this.form.submit()" form="filterForm">
            <option value="">-- Tất cả thương hiệu --</option>
            @foreach (var th in thuongHieus)
            {
                <option value="@th.IDTH" selected="@(ViewBag.Brand == th.IDTH)">@th.TENTHUONGHIEU</option>
            }
        </select>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-custom table-hover align-middle">
        <thead>
            <tr>
                <th>ID SP</th>
                <th>Tên sản phẩm</th>
                <th>Giá (VNĐ)</th>
                <th>Số lượng</th>
                <th>Danh mục</th>
                <th>Thương hiệu</th>
                <th>Trạng thái</th>
                <th>Hành động</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Any())
            {
                foreach (var item in Model)
                {
                    var dm = danhMucs?.FirstOrDefault(d => d.IDDM == item.IDDM);
                    var th = thuongHieus?.FirstOrDefault(t => t.IDTH == item.IDTH);
                    <tr>
                        <td>@item.IDSP</td>
                        <td>@item.TENSP</td>
                        <td>@item.GIA.ToString("N0")</td>
                        <td>@item.SOLUONG</td>
                        <td>@(dm?.TENDANHMUC ?? "N/A")</td>
                        <td>@(th?.TENTHUONGHIEU ?? "N/A")</td>
                        <td>
                            @if (item.TRANGTHAI)
                            {
                                <span class="badge bg-success">Đang bán</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Ngừng bán</span>
                            }
                        </td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.IDSP" class="btn btn-sm btn-info"><i class="fas fa-eye"></i></a>
                            <a asp-action="Edit" asp-route-id="@item.IDSP" class="btn btn-sm btn-warning"><i class="fas fa-edit"></i></a>
                            <a asp-action="Delete" asp-route-id="@item.IDSP" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="8" class="text-center">Không có dữ liệu</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (ViewBag.TotalPages > 1)
{
    <nav class="mt-4">
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.Page ? "active" : "")">
                    <a class="page-link" href="@Url.Action("Index", new { search = ViewBag.Search, category = ViewBag.Category, brand = ViewBag.Brand, page = i, pageSize = ViewBag.PageSize })">@i</a>
                </li>
            }
        </ul>
    </nav>
}