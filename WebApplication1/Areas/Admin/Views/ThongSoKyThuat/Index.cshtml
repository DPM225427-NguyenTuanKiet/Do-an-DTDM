@model List<CarShop.Models.ThongSoKyThuat>
@{
    ViewData["Title"] = "Quản lý thông số kỹ thuật";
    Layout = "_AdminLayout";
    var sanPhams = ViewBag.SanPhams as List<CarShop.Models.SanPham>;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-microchip me-2"></i>Thông số kỹ thuật</h2>
    <a asp-action="Create" class="btn btn-orange"><i class="fas fa-plus"></i> Thêm mới</a>
</div>

<div class="row mb-3">
    <div class="col-md-4">
        <form method="get" asp-action="Index" class="search-bar">
            <i class="fas fa-search"></i>
            <input type="text" name="search" placeholder="Tìm theo ID, sản phẩm, loại động cơ..." value="@ViewBag.Search" autocomplete="off" />
            <button type="submit"><i class="fas fa-arrow-right"></i></button>
        </form>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-custom table-hover align-middle">
        <thead>
            <tr>
                <th>ID TS</th>
                <th>Sản phẩm</th>
                <th>Loại động cơ</th>
                <th>Dung tích</th>
                <th>Công suất</th>
                <th>Mô-men xoắn</th>
                <th>Hộp số</th>
                <th>Nhiên liệu</th>
                <th>Hệ dẫn động</th>
                <th>Tiêu thụ</th>
                <th>Kích thước</th>
                <th>Khối lượng</th>
                <th>Số chỗ</th>
                <th>Hành động</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Any())
            {
                foreach (var item in Model)
                {
                    var sp = sanPhams?.FirstOrDefault(s => s.IDSP == item.IDSP);
                    <tr>
                        <td>@item.IDTS</td>
                        <td>@(sp?.TENSP ?? "N/A")</td>
                        <td>@(item.LOAI_DONG_CO ?? "")</td>
                        <td>@(item.DUNG_TICH ?? "")</td>
                        <td>@(item.CONG_SUAT ?? "")</td>
                        <td>@(item.MO_MEN_XOAN ?? "")</td>
                        <td>@(item.HOP_SO ?? "")</td>
                        <td>@(item.NHIEN_LIEU ?? "")</td>
                        <td>@(item.DAN_DONG ?? "")</td>
                        <td>@(item.TIEU_THU_NHIEN_LIEU ?? "")</td>
                        <td>@(item.KICH_THUOC ?? "")</td>
                        <td>@(item.KHOI_LUONG ?? "")</td>
                        <td>@(item.SO_CHO?.ToString() ?? "")</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.IDTS" class="btn btn-sm btn-info"><i class="fas fa-eye"></i></a>
                            <a asp-action="Edit" asp-route-id="@item.IDTS" class="btn btn-sm btn-warning"><i class="fas fa-edit"></i></a>
                            <a asp-action="Delete" asp-route-id="@item.IDTS" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="14" class="text-center">Không có dữ liệu</td></tr>
            }
        </tbody>
    </table>
</div>

@if (ViewBag.TotalPages > 1)
{
    <nav class="mt-4">
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.Page ? "active" : "")">
                    <a class="page-link" href="@Url.Action("Index", new { search = ViewBag.Search, page = i, pageSize = ViewBag.PageSize })">@i</a>
                </li>
            }
        </ul>
    </nav>
}