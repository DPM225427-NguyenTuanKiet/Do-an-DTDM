@model CarShop.Models.NhanVien
@{
    ViewData["Title"] = "Xóa nhân viên";
    Layout = "_AdminLayout";
    var taiKhoan = ViewBag.TaiKhoan as CarShop.Models.TaiKhoan;
    var chucVu = ViewBag.ChucVu as CarShop.Models.ChucVu;
}

<div class="card shadow-sm">
    <div class="card-header bg-danger text-white">
        <h4><i class="fas fa-exclamation-triangle"></i> Xác nhận xóa nhân viên</h4>
    </div>
    <div class="card-body">
        <div class="alert alert-warning">
            <i class="fas fa-info-circle"></i> Bạn có chắc chắn muốn xóa nhân viên <strong>@(Model.HOTEN ?? "này")</strong>? Hành động không thể hoàn tác.
        </div>
        <dl class="row">
            <dt class="col-sm-3">ID NV</dt>
            <dd class="col-sm-9">@Model.IDNV</dd>
            <dt class="col-sm-3">Họ tên</dt>
            <dd class="col-sm-9">@(Model.HOTEN ?? "")</dd>
            <dt class="col-sm-3">Điện thoại</dt>
            <dd class="col-sm-9">@(Model.DIENTHOAI ?? "")</dd>
            <dt class="col-sm-3">Chức vụ</dt>
            <dd class="col-sm-9">@(Model.CHUCVU ?? chucVu?.TENCV ?? "")</dd>
        </dl>
        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="IDNV" />
            <button type="submit" class="btn btn-danger"><i class="fas fa-trash-alt"></i> Xóa</button>
            <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Quay lại</a>
        </form>
    </div>
</div>