@model List<CarShop.Models.NhanVien>
@{
    ViewData["Title"] = "Quản lý nhân viên";
    Layout = "_AdminLayout";
    var taiKhoans = ViewBag.TaiKhoans as List<CarShop.Models.TaiKhoan>;
    var chucVus = ViewBag.ChucVus as List<CarShop.Models.ChucVu>;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-users me-2"></i>Quản lý nhân viên</h2>
    <a asp-action="Create" class="btn btn-orange"><i class="fas fa-plus"></i> Thêm nhân viên</a>
</div>

<div class="row mb-3">
    <div class="col-md-4">
        <form method="get" asp-action="Index" class="search-bar">
            <i class="fas fa-search"></i>
            <input type="text" name="search" placeholder="Tìm theo tên, số điện thoại, chức vụ..." value="@ViewBag.Search" autocomplete="off">
            <button type="submit"><i class="fas fa-arrow-right"></i></button>
        </form>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-custom table-hover align-middle">
        <thead>
            <tr>
                <th>ID NV</th>
                <th>Họ tên</th>
                <th>Điện thoại</th>
                <th>Chức vụ</th>
                <th>Lương CB</th>
                <th>Giờ làm</th>
                <th>Giờ nghỉ</th>
                <th>Tổng lương</th>
                <th>Ngày vào</th>
                <th>Hành động</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Any())
            {
                foreach (var item in Model)
                {
                    var taiKhoan = taiKhoans?.FirstOrDefault(t => t.IDTK == item.IDTK);
                    var chucVu = chucVus?.FirstOrDefault(c => c.IDCV == item.IDCV);
                    <tr>
                        <td>@item.IDNV</td>
                        <td>@(item.HOTEN ?? "")</td>
                        <td>@(item.DIENTHOAI ?? "")</td>
                        <td>@(item.CHUCVU ?? chucVu?.TENCV ?? "")</td>
                        <td>@(item.LUONGCB?.ToString("N0") ?? "0")</td>
                        <td>@(item.GIOLAM ?? 0)</td>
                        <td>@(item.GIONGHI ?? 0)</td>
                        <td>@(item.TONGLUONG?.ToString("N0") ?? "0")</td>
                        <td>@(item.NGAYVAOLAM?.ToString("dd/MM/yyyy") ?? "")</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.IDNV" class="btn btn-sm btn-info"><i class="fas fa-eye"></i></a>
                            <a asp-action="Edit" asp-route-id="@item.IDNV" class="btn btn-sm btn-warning"><i class="fas fa-edit"></i></a>
                            <a asp-action="Delete" asp-route-id="@item.IDNV" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="10" class="text-center">Không có dữ liệu</td></tr>
            }
        </tbody>
    </table>
</div>

@if (ViewBag.TotalPages > 1)
{
    <nav class="mt-4">
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.Page ? "active" : "")">
                    <a class="page-link" href="@Url.Action("Index", new { search = ViewBag.Search, page = i, pageSize = ViewBag.PageSize })">@i</a>
                </li>
            }
        </ul>
    </nav>
}