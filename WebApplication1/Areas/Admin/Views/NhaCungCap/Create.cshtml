@model CarShop.Models.NhaCungCap
@{
    ViewData["Title"] = "Thêm nhà cung cấp";
    Layout = "_AdminLayout";
}

<div class="card shadow-sm">
    <div class="card-header bg-success text-white">
        <h4><i class="fas fa-plus"></i> Thêm nhà cung cấp mới</h4>
    </div>
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label asp-for="TENNCC" class="form-label">Tên nhà cung cấp</label>
                        <input asp-for="TENNCC" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="DIACHI" class="form-label">Địa chỉ</label>
                        <textarea asp-for="DIACHI" class="form-control" rows="3"></textarea>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label asp-for="DIENTHOAI" class="form-label">Điện thoại</label>
                        <input asp-for="DIENTHOAI" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="EMAIL" class="form-label">Email</label>
                        <input asp-for="EMAIL" type="email" class="form-control" />
                    </div>
                </div>
            </div>
            <button type="submit" class="btn btn-orange"><i class="fas fa-save"></i> Lưu</button>
            <a asp-action="Index" class="btn btn-secondary">Hủy</a>
        </form>
    </div>
</div>