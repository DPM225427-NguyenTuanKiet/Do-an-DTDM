@model CarShop.Models.NhaCungCap
@{
    ViewData["Title"] = "Xóa nhà cung cấp";
    Layout = "_AdminLayout";
}

<div class="card shadow-sm">
    <div class="card-header bg-danger text-white">
        <h4><i class="fas fa-exclamation-triangle"></i> Xác nhận xóa nhà cung cấp</h4>
    </div>
    <div class="card-body">
        <div class="alert alert-warning">
            <i class="fas fa-info-circle"></i> Bạn có chắc chắn muốn xóa nhà cung cấp <strong>@(Model.TENNCC ?? "này")</strong>? Hành động không thể hoàn tác.
        </div>
        <dl class="row">
            <dt class="col-sm-3">ID NCC</dt>
            <dd class="col-sm-9">@Model.IDNCC</dd>
            <dt class="col-sm-3">Tên nhà cung cấp</dt>
            <dd class="col-sm-9">@(Model.TENNCC ?? "")</dd>
            <dt class="col-sm-3">Địa chỉ</dt>
            <dd class="col-sm-9">@(Model.DIACHI ?? "")</dd>
            <dt class="col-sm-3">Điện thoại</dt>
            <dd class="col-sm-9">@(Model.DIENTHOAI ?? "")</dd>
            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@(Model.EMAIL ?? "")</dd>
        </dl>
        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="IDNCC" />
            <button type="submit" class="btn btn-danger"><i class="fas fa-trash-alt"></i> Xóa</button>
            <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Quay lại</a>
        </form>
    </div>
</div>