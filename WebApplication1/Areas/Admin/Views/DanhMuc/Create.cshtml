@model CarShop.Models.DanhMuc
@{
    ViewData["Title"] = "Thêm danh mục";
    Layout = "_AdminLayout";
}

<div class="card shadow-sm">
    <div class="card-header bg-success text-white">
        <h4><i class="fas fa-plus"></i> Thêm danh mục mới</h4>
    </div>
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div class="mb-3">
                <label asp-for="TENDANHMUC" class="form-label">Tên danh mục</label>
                <input asp-for="TENDANHMUC" class="form-control" required />
            </div>
            <button type="submit" class="btn btn-orange"><i class="fas fa-save"></i> Lưu</button>
            <a asp-action="Index" class="btn btn-secondary">Hủy</a>
        </form>
    </div>
</div>