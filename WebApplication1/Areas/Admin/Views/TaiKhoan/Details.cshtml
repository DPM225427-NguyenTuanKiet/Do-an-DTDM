@model CarShop.Models.TaiKhoan
@{
    ViewData["Title"] = "Chi tiết tài khoản";
    Layout = "_AdminLayout";
}

<div class="card shadow-sm">
    <div class="card-header bg-primary text-white">
        <h4><i class="fas fa-info-circle"></i> Chi tiết tài khoản #@Model.IDTK</h4>
    </div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">ID TK</dt>
            <dd class="col-sm-9">@Model.IDTK</dd>
            <dt class="col-sm-3">Tên đăng nhập</dt>
            <dd class="col-sm-9">@Model.TENDANGNHAP</dd>
            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@Model.EMAIL</dd>
            <dt class="col-sm-3">Vai trò</dt>
            <dd class="col-sm-9">@Model.VAITRO</dd>
            <dt class="col-sm-3">Trạng thái</dt>
            <dd class="col-sm-9">
                @if (Model.TRANGTHAI)
                {
                    <span class="badge bg-success">Hoạt động</span>
                }
                else
                {
                    <span class="badge bg-secondary">Khóa</span>
                }
            </dd>
            <dt class="col-sm-3">Ngày tạo</dt>
            <dd class="col-sm-9">@Model.NGAYTAO.ToString("dd/MM/yyyy HH:mm")</dd>
        </dl>
    </div>
    <div class="card-footer">
        <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Quay lại</a>
        <a asp-action="Edit" asp-route-id="@Model.IDTK" class="btn btn-warning"><i class="fas fa-edit"></i> Sửa</a>
        <a asp-action="Delete" asp-route-id="@Model.IDTK" class="btn btn-danger"><i class="fas fa-trash"></i> Xóa</a>
    </div>
</div>