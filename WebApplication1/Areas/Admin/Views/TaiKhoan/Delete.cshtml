@model CarShop.Models.TaiKhoan
@{
    ViewData["Title"] = "Xóa tài khoản";
    Layout = "_AdminLayout";
}

<div class="card shadow-sm">
    <div class="card-header bg-danger text-white">
        <h4><i class="fas fa-exclamation-triangle"></i> Xác nhận xóa tài khoản</h4>
    </div>
    <div class="card-body">
        <div class="alert alert-warning">
            <i class="fas fa-info-circle"></i> Bạn có chắc chắn muốn xóa tài khoản <strong>@Model.TENDANGNHAP</strong>? Hành động không thể hoàn tác.
        </div>
        <dl class="row">
            <dt class="col-sm-3">ID TK</dt>
            <dd class="col-sm-9">@Model.IDTK</dd>
            <dt class="col-sm-3">Tên đăng nhập</dt>
            <dd class="col-sm-9">@Model.TENDANGNHAP</dd>
            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@Model.EMAIL</dd>
            <dt class="col-sm-3">Vai trò</dt>
            <dd class="col-sm-9">@Model.VAITRO</dd>
        </dl>
        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="IDTK" />
            <button type="submit" class="btn btn-danger"><i class="fas fa-trash-alt"></i> Xóa</button>
            <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Quay lại</a>
        </form>
    </div>
</div>