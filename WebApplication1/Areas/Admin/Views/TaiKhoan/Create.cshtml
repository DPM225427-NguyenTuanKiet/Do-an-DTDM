@model CarShop.Models.TaiKhoan
@{
    ViewData["Title"] = "Thêm tài khoản";
    Layout = "_AdminLayout";
}

<div class="card shadow-sm">
    <div class="card-header bg-success text-white">
        <h4><i class="fas fa-plus"></i> Thêm tài khoản mới</h4>
    </div>
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label asp-for="TENDANGNHAP" class="form-label">Tên đăng nhập</label>
                        <input asp-for="TENDANGNHAP" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label for="password" class="form-label">Mật khẩu</label>
                        <input type="password" name="password" id="password" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label asp-for="EMAIL" class="form-label">Email</label>
                        <input asp-for="EMAIL" type="email" class="form-control" required />
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label asp-for="VAITRO" class="form-label">Vai trò</label>
                        <select asp-for="VAITRO" class="form-select" required>
                            <option value="">-- Chọn vai trò --</option>
                            <option value="admin">Admin</option>
                            <option value="customer">Khách hàng</option>
                            <option value="employee">Nhân viên</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label asp-for="TRANGTHAI" class="form-label">Trạng thái</label>
                        <select asp-for="TRANGTHAI" class="form-select">
                            <option value="true">Hoạt động</option>
                            <option value="false">Khóa</option>
                        </select>
                    </div>
                </div>
            </div>
            <button type="submit" class="btn btn-orange"><i class="fas fa-save"></i> Lưu</button>
            <a asp-action="Index" class="btn btn-secondary">Hủy</a>
        </form>
    </div>
</div>