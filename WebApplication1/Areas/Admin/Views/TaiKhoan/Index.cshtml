@model List<CarShop.Models.TaiKhoan>
@{
    ViewData["Title"] = "Quản lý tài khoản";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-users me-2"></i>Quản lý tài khoản</h2>
    <a asp-action="Create" class="btn btn-orange"><i class="fas fa-plus"></i> Thêm tài khoản</a>
</div>

<div class="row mb-3">
    <div class="col-md-4">
        <form method="get" asp-action="Index" class="search-bar">
            <i class="fas fa-search"></i>
            <input type="text" name="search" placeholder="Tìm theo tên, email, vai trò..." value="@ViewBag.Search" autocomplete="off" />
            <button type="submit"><i class="fas fa-arrow-right"></i></button>
        </form>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-custom table-hover align-middle">
        <thead>
            <tr>
                <th>ID TK</th>
                <th>Tên đăng nhập</th>
                <th>Email</th>
                <th>Vai trò</th>
                <th>Trạng thái</th>
                <th>Ngày tạo</th>
                <th>Hành động</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.IDTK</td>
                        <td>@item.TENDANGNHAP</td>
                        <td>@item.EMAIL</td>
                        <td>@item.VAITRO</td>
                        <td>
                            @if (item.TRANGTHAI)
                            {
                                <span class="badge bg-success">Hoạt động</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Khóa</span>
                            }
                        </td>
                        <td>@item.NGAYTAO.ToString("dd/MM/yyyy")</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.IDTK" class="btn btn-sm btn-info"><i class="fas fa-eye"></i></a>
                            <a asp-action="Edit" asp-route-id="@item.IDTK" class="btn btn-sm btn-warning"><i class="fas fa-edit"></i></a>
                            <a asp-action="Delete" asp-route-id="@item.IDTK" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="7" class="text-center">Không có dữ liệu</td></tr>
            }
        </tbody>
    </table>
</div>

@if (ViewBag.TotalPages > 1)
{
    <nav class="mt-4">
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.Page ? "active" : "")">
                    <a class="page-link" href="@Url.Action("Index", new { search = ViewBag.Search, page = i, pageSize = ViewBag.PageSize })">@i</a>
                </li>
            }
        </ul>
    </nav>
}