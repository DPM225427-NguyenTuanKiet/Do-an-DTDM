@model CarShop.Models.PhieuNhap
@{
    ViewData["Title"] = "Xóa phiếu nhập";
    Layout = "_AdminLayout";
    var nhaCungCap = ViewBag.NhaCungCap as CarShop.Models.NhaCungCap;
    var nhanVien = ViewBag.NhanVien as CarShop.Models.NhanVien;
    var kho = ViewBag.Kho as CarShop.Models.Kho;
}

<div class="card shadow-sm">
    <div class="card-header bg-danger text-white">
        <h4><i class="fas fa-exclamation-triangle"></i> Xác nhận xóa phiếu nhập</h4>
    </div>
    <div class="card-body">
        <div class="alert alert-warning">
            <i class="fas fa-info-circle"></i> Bạn có chắc chắn muốn xóa phiếu nhập #@Model.IDPN? Hành động không thể hoàn tác.
        </div>
        <dl class="row">
            <dt class="col-sm-3">ID PN</dt>
            <dd class="col-sm-9">@Model.IDPN</dd>
            <dt class="col-sm-3">Ngày nhập</dt>
            <dd class="col-sm-9">@Model.NGAYNHAP.ToString("dd/MM/yyyy HH:mm")</dd>
            <dt class="col-sm-3">Nhà cung cấp</dt>
            <dd class="col-sm-9">@(nhaCungCap?.TENNCC ?? "N/A")</dd>
            <dt class="col-sm-3">Nhân viên</dt>
            <dd class="col-sm-9">@(nhanVien?.HOTEN ?? "N/A")</dd>
            <dt class="col-sm-3">Kho</dt>
            <dd class="col-sm-9">@(kho?.TENKHO ?? "N/A")</dd>
            <dt class="col-sm-3">Tổng số sản phẩm</dt>
            <dd class="col-sm-9">@Model.CHITIET.Sum(c => c.SOLUONG)</dd>
        </dl>
        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="IDPN" />
            <button type="submit" class="btn btn-danger"><i class="fas fa-trash-alt"></i> Xóa</button>
            <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Quay lại</a>
        </form>
    </div>
</div>