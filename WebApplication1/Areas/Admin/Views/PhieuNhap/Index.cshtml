@model List<CarShop.Models.PhieuNhap>
@{
    ViewData["Title"] = "Quản lý phiếu nhập";
    Layout = "_AdminLayout";
    var nhaCungCaps = ViewBag.NhaCungCaps as List<CarShop.Models.NhaCungCap>;
    var nhanViens = ViewBag.NhanViens as List<CarShop.Models.NhanVien>;
    var khos = ViewBag.Khos as List<CarShop.Models.Kho>;
    var sanPhams = ViewBag.SanPhams as List<CarShop.Models.SanPham>;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-truck-loading me-2"></i>Quản lý phiếu nhập</h2>
    <div>
        <a asp-action="ExportExcel" class="btn btn-success me-2"><i class="fas fa-file-excel"></i> Xuất Excel</a>
        <a asp-action="Create" class="btn btn-orange"><i class="fas fa-plus"></i> Thêm phiếu nhập</a>
    </div>
</div>

<div class="row mb-3">
    <div class="col-md-4">
        <form method="get" asp-action="Index" class="search-bar">
            <i class="fas fa-search"></i>
            <input type="text" name="search" placeholder="Tìm theo ID, NCC, NV, kho, tên SP..." value="@ViewBag.Search" autocomplete="off">
            <button type="submit"><i class="fas fa-arrow-right"></i></button>
        </form>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-custom table-hover align-middle">
        <thead>
            <tr>
                <th>ID PN</th>
                <th>Ngày nhập</th>
                <th>Nhà cung cấp</th>
                <th>Nhân viên</th>
                <th>Kho</th>
                <th>Số lượng SP</th>
                <th>Hành động</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Any())
            {
                foreach (var item in Model)
                {
                    var ncc = nhaCungCaps?.FirstOrDefault(n => n.IDNCC == item.IDNCC);
                    var nv = nhanViens?.FirstOrDefault(n => n.IDNV == item.IDNV);
                    var kho = khos?.FirstOrDefault(k => k.IDKHO == item.IDKHO);
                    <tr>
                        <td>@item.IDPN</td>
                        <td>@item.NGAYNHAP.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@(ncc?.TENNCC ?? "N/A")</td>
                        <td>@(nv?.HOTEN ?? "N/A")</td>
                        <td>@(kho?.TENKHO ?? "N/A")</td>
                        <td>@item.CHITIET.Sum(c => c.SOLUONG)</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.IDPN" class="btn btn-sm btn-info"><i class="fas fa-eye"></i></a>
                            <a asp-action="Edit" asp-route-id="@item.IDPN" class="btn btn-sm btn-warning"><i class="fas fa-edit"></i></a>
                            <a asp-action="Delete" asp-route-id="@item.IDPN" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="7" class="text-center">Không có phiếu nhập nào</td></tr>
            }
        </tbody>
    </table>
</div>

@if (ViewBag.TotalPages > 1)
{
    <nav class="mt-4">
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.Page ? "active" : "")">
                    <a class="page-link" href="@Url.Action("Index", new { search = ViewBag.Search, page = i, pageSize = ViewBag.PageSize })">@i</a>
                </li>
            }
        </ul>
    </nav>
}
