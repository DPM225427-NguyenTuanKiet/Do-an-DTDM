@model CarShop.Models.BinhLuan
@{
    ViewData["Title"] = "Chi tiết bình luận";
    Layout = "_AdminLayout";
    var sanPham = ViewBag.SanPham as CarShop.Models.SanPham;
    var taiKhoan = ViewBag.TaiKhoan as CarShop.Models.TaiKhoan;
}

<div class="card shadow-sm">
    <div class="card-header bg-primary text-white">
        <h4><i class="fas fa-info-circle"></i> Chi tiết bình luận #@Model.IDBL</h4>
    </div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">ID BL</dt>
            <dd class="col-sm-9">@Model.IDBL</dd>

            <dt class="col-sm-3">Sản phẩm</dt>
            <dd class="col-sm-9">@(sanPham?.TENSP ?? "N/A")</dd>

            <dt class="col-sm-3">Người dùng</dt>
            <dd class="col-sm-9">@(taiKhoan?.TENDANGNHAP ?? "N/A")</dd>

            <dt class="col-sm-3">Nội dung</dt>
            <dd class="col-sm-9">@Model.NOIDUNG</dd>

            <dt class="col-sm-3">Ngày tạo</dt>
            <dd class="col-sm-9">@(Model.NGAYTAO?.ToString("dd/MM/yyyy HH:mm:ss") ?? "")</dd>

            <dt class="col-sm-3">Số sao</dt>
            <dd class="col-sm-9">
                @for (int i = 1; i <= 5; i++)
                {
                    if (Model.SOSAO >= i)
                    {
                        <i class="fas fa-star text-warning"></i>
                    }
                    else
                    {
                        <i class="far fa-star text-secondary"></i>
                    }
                }
            </dd>
        </dl>
    </div>
    <div class="card-footer">
        <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Quay lại</a>
        <a asp-action="Delete" asp-route-id="@Model.IDBL" class="btn btn-danger"><i class="fas fa-trash"></i> Xóa</a>
    </div>
</div>