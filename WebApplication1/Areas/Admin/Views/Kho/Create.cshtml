@model CarShop.Models.Kho
@{
    ViewData["Title"] = "Thêm kho mới";
    Layout = "_AdminLayout";
}

<div class="card shadow-sm">
    <div class="card-header bg-success text-white">
        <h4><i class="fas fa-plus"></i> Thêm kho mới</h4>
    </div>
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div class="mb-3">
                <label asp-for="TENKHO" class="form-label">Tên kho</label>
                <input asp-for="TENKHO" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="DIACHI" class="form-label">Địa chỉ</label>
                <textarea asp-for="DIACHI" class="form-control" rows="3"></textarea>
            </div>
            <button type="submit" class="btn btn-orange"><i class="fas fa-save"></i> Lưu</button>
            <a asp-action="Index" class="btn btn-secondary">Hủy</a>
        </form>
    </div>
</div>