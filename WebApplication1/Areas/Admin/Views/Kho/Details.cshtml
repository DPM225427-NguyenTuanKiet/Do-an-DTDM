@model CarShop.Models.Kho
@{
    ViewData["Title"] = "Chi tiết kho";
    Layout = "_AdminLayout";
}

<div class="card shadow-sm">
    <div class="card-header bg-primary text-white">
        <h4><i class="fas fa-info-circle"></i> Chi tiết kho #@Model.IDKHO</h4>
    </div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">ID Kho</dt>
            <dd class="col-sm-9">@Model.IDKHO</dd>
            <dt class="col-sm-3">Tên kho</dt>
            <dd class="col-sm-9">@(Model.TENKHO ?? "")</dd>
            <dt class="col-sm-3">Địa chỉ</dt>
            <dd class="col-sm-9">@(Model.DIACHI ?? "")</dd>
        </dl>
    </div>
    <div class="card-footer">
        <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Quay lại</a>
        <a asp-action="Edit" asp-route-id="@Model.IDKHO" class="btn btn-warning"><i class="fas fa-edit"></i> Sửa</a>
        <a asp-action="Delete" asp-route-id="@Model.IDKHO" class="btn btn-danger"><i class="fas fa-trash"></i> Xóa</a>
    </div>
</div>