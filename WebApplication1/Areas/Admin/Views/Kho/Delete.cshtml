@model CarShop.Models.Kho
@{
    ViewData["Title"] = "Xóa kho";
    Layout = "_AdminLayout";
}

<div class="card shadow-sm">
    <div class="card-header bg-danger text-white">
        <h4><i class="fas fa-exclamation-triangle"></i> Xác nhận xóa kho</h4>
    </div>
    <div class="card-body">
        <div class="alert alert-warning">
            <i class="fas fa-info-circle"></i> Bạn có chắc chắn muốn xóa kho <strong>@(Model.TENKHO ?? "này")</strong>? Hành động không thể hoàn tác.
        </div>
        <dl class="row">
            <dt class="col-sm-3">ID Kho</dt>
            <dd class="col-sm-9">@Model.IDKHO</dd>
            <dt class="col-sm-3">Tên kho</dt>
            <dd class="col-sm-9">@(Model.TENKHO ?? "")</dd>
            <dt class="col-sm-3">Địa chỉ</dt>
            <dd class="col-sm-9">@(Model.DIACHI ?? "")</dd>
        </dl>
        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="IDKHO" />
            <button type="submit" class="btn btn-danger"><i class="fas fa-trash-alt"></i> Xóa</button>
            <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Quay lại</a>
        </form>
    </div>
</div>