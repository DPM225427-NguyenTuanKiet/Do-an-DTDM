@model CarShop.Models.QuaTang
@{
    ViewData["Title"] = "Xóa quà tặng";
    Layout = "_AdminLayout";
}

<div class="card shadow-sm">
    <div class="card-header bg-danger text-white">
        <h4><i class="fas fa-exclamation-triangle"></i> Xác nhận xóa quà tặng</h4>
    </div>
    <div class="card-body">
        <div class="alert alert-warning">
            <i class="fas fa-info-circle"></i> Bạn có chắc chắn muốn xóa quà tặng <strong>@Model.TENQUATANG</strong>? Hành động không thể hoàn tác.
        </div>
        <dl class="row">
            <dt class="col-sm-3">ID QT</dt>
            <dd class="col-sm-9">@Model.IDQT</dd>
            <dt class="col-sm-3">Tên quà tặng</dt>
            <dd class="col-sm-9">@Model.TENQUATANG</dd>
            <dt class="col-sm-3">Điểm đổi</dt>
            <dd class="col-sm-9">@Model.DIEM_DOI</dd>
            <dt class="col-sm-3">Số lượng</dt>
            <dd class="col-sm-9">@Model.SOLUONG</dd>
        </dl>
        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="IDQT" />
            <button type="submit" class="btn btn-danger"><i class="fas fa-trash-alt"></i> Xóa</button>
            <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Quay lại</a>
        </form>
    </div>
</div>