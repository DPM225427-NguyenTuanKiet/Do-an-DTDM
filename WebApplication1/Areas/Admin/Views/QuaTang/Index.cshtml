@model List<CarShop.Models.QuaTang>
@{
    ViewData["Title"] = "Quản lý quà tặng";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-gift me-2"></i>Quản lý quà tặng đổi điểm</h2>
    <a asp-action="Create" class="btn btn-orange"><i class="fas fa-plus"></i> Thêm quà tặng</a>
</div>

<div class="row mb-3">
    <div class="col-md-4">
        <form method="get" asp-action="Index" class="search-bar">
            <i class="fas fa-search"></i>
            <input type="text" name="search" placeholder="Tìm theo tên hoặc mô tả..." value="@ViewBag.Search" autocomplete="off">
            <button type="submit"><i class="fas fa-arrow-right"></i></button>
        </form>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-custom table-hover align-middle">
        <thead>
            <tr>
                <th>ID QT</th>
                <th>Tên quà tặng</th>
                <th>Điểm đổi</th>
                <th>Số lượng</th>
                <th>Mô tả</th>
                <th>Hình ảnh</th>
                <th>Trạng thái</th>
                <th>Hành động</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.IDQT</td>
                        <td>@item.TENQUATANG</td>
                        <td>@item.DIEM_DOI</td>
                        <td>@item.SOLUONG</td>
                        <td>@(item.MOTA ?? "")</td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.HINHANH))
                            {
                                <img src="@item.HINHANH" style="max-width: 50px; max-height: 50px;" class="img-thumbnail" />
                            }
                            else
                            {
                                <span>Chưa có ảnh</span>
                            }
                        </td>
                        <td>
                            @if (item.TRANGTHAI)
                            {
                                <span class="badge bg-success">Đang áp dụng</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Ngừng áp dụng</span>
                            }
                        </td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.IDQT" class="btn btn-sm btn-info"><i class="fas fa-eye"></i></a>
                            <a asp-action="Edit" asp-route-id="@item.IDQT" class="btn btn-sm btn-warning"><i class="fas fa-edit"></i></a>
                            <a asp-action="Delete" asp-route-id="@item.IDQT" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="8" class="text-center">Không có dữ liệu</td></tr>
            }
        </tbody>
    </table>
</div>

@if (ViewBag.TotalPages > 1)
{
    <nav class="mt-4">
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.Page ? "active" : "")">
                    <a class="page-link" href="@Url.Action("Index", new { search = ViewBag.Search, page = i, pageSize = ViewBag.PageSize })">@i</a>
                </li>
            }
        </ul>
    </nav>
}