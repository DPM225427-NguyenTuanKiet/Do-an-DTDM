@model CarShop.Models.HinhAnh
@{
    ViewData["Title"] = "Chi tiết hình ảnh";
    Layout = "_AdminLayout";
    var sanPham = ViewBag.SanPham as CarShop.Models.SanPham;
}

<div class="card shadow-sm">
    <div class="card-header bg-primary text-white">
        <h4><i class="fas fa-info-circle"></i> Chi tiết hình ảnh</h4>
    </div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">ID</dt>
            <dd class="col-sm-9">@Model.IDHINHANH</dd>
            <dt class="col-sm-3">Sản phẩm</dt>
            <dd class="col-sm-9">@(sanPham?.TENSP ?? "Không xác định") (ID: @Model.IDSP)</dd>
            <dt class="col-sm-3">Đường dẫn</dt>
            <dd class="col-sm-9">@Model.DUONGDAN</dd>
            <dt class="col-sm-3">Hình ảnh</dt>
            <dd class="col-sm-9">
                @if (!string.IsNullOrEmpty(Model.DUONGDAN))
                {
                    <img src="@Model.DUONGDAN" alt="Hình ảnh" style="max-width: 300px;" class="img-thumbnail" onerror="this.src='/images/placeholder.jpg'" />
                }
                else
                {
                    <span>Chưa có ảnh</span>
                }
            </dd>
        </dl>
    </div>
    <div class="card-footer">
        <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Quay lại</a>
        <a asp-action="Edit" asp-route-id="@Model.IDHINHANH" class="btn btn-warning"><i class="fas fa-edit"></i> Sửa</a>
        <a asp-action="Delete" asp-route-id="@Model.IDHINHANH" class="btn btn-danger"><i class="fas fa-trash"></i> Xóa</a>
    </div>
</div>