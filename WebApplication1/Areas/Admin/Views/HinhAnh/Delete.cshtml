@model CarShop.Models.HinhAnh
@{
    ViewData["Title"] = "Xóa hình ảnh";
    Layout = "_AdminLayout";
    var sanPham = ViewBag.SanPham as CarShop.Models.SanPham;
}

<div class="card shadow-sm">
    <div class="card-header bg-danger text-white">
        <h4><i class="fas fa-exclamation-triangle"></i> Xác nhận xóa hình ảnh</h4>
    </div>
    <div class="card-body">
        <div class="alert alert-warning">
            <i class="fas fa-info-circle"></i> Bạn có chắc chắn muốn xóa hình ảnh này? Hành động không thể hoàn tác.
        </div>
        <dl class="row">
            <dt class="col-sm-3">ID</dt>
            <dd class="col-sm-9">@Model.IDHINHANH</dd>
            <dt class="col-sm-3">Sản phẩm</dt>
            <dd class="col-sm-9">@(sanPham?.TENSP ?? "Không xác định")</dd>
            <dt class="col-sm-3">Đường dẫn</dt>
            <dd class="col-sm-9">@Model.DUONGDAN</dd>
        </dl>
        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="IDHINHANH" />
            <button type="submit" class="btn btn-danger"><i class="fas fa-trash-alt"></i> Xóa</button>
            <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Quay lại</a>
        </form>
    </div>
</div>