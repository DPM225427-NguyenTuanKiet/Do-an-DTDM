@model List<CarShop.Models.KhachHang>
@{
    ViewData["Title"] = "Quản lý khách hàng";
    Layout = "_AdminLayout";
    var taiKhoans = ViewBag.TaiKhoans as List<CarShop.Models.TaiKhoan>;
    var loaiGias = ViewBag.LoaiGias as List<CarShop.Models.LoaiGia>;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-users me-2"></i>Quản lý khách hàng</h2>
    <a asp-action="Create" class="btn btn-orange"><i class="fas fa-plus"></i> Thêm mới</a>
</div>

<div class="row mb-3">
    <div class="col-md-4">
        <form method="get" asp-action="Index" class="search-bar">
            <i class="fas fa-search"></i>
            <input type="text" name="search" placeholder="Tìm theo tên, email, số điện thoại..." value="@ViewBag.Search" autocomplete="off">
            <button type="submit"><i class="fas fa-arrow-right"></i></button>
        </form>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-custom table-hover align-middle">
        <thead>
            <tr>
                <th>ID KH</th>
                <th>Họ tên</th>
                <th>Email</th>
                <th>Số điện thoại</th>
                <th>Địa chỉ</th>
                <th>Tài khoản</th>
                <th>Hạng</th>
                <th>Hành động</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Any())
            {
                foreach (var item in Model)
                {
                    var taiKhoan = taiKhoans?.FirstOrDefault(t => t.IDTK == item.IDTK);
                    var loaiGia = loaiGias?.FirstOrDefault(l => l.IDLG == item.IDLG);
                    <tr>
                        <td>@item.IDKH</td>
                        <td>@item.HOTEN</td>
                        <td>@item.EMAIL</td>
                        <td>@item.DIENTHOAI</td>
                        <td>@item.DIACHI</td>
                        <td>@(taiKhoan?.TENDANGNHAP ?? "N/A")</td>
                        <td>@(loaiGia?.TENLOAI ?? "N/A")</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.IDKH" class="btn btn-sm btn-info"><i class="fas fa-eye"></i></a>
                            <a asp-action="Edit" asp-route-id="@item.IDKH" class="btn btn-sm btn-warning"><i class="fas fa-edit"></i></a>
                            <a asp-action="Delete" asp-route-id="@item.IDKH" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="8" class="text-center">Không có khách hàng nào</td></tr>
            }
        </tbody>
    </table>
</div>

@if (ViewBag.TotalPages > 1)
{
    <nav class="mt-4">
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.Page ? "active" : "")">
                    <a class="page-link" href="@Url.Action("Index", new { search = ViewBag.Search, page = i, pageSize = ViewBag.PageSize })">@i</a>
                </li>
            }
        </ul>
    </nav>
}