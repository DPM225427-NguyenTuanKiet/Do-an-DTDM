@model CarShop.Models.KhachHang
@{
    ViewData["Title"] = "Xóa khách hàng";
    Layout = "_AdminLayout";
    var taiKhoan = ViewBag.TaiKhoan as CarShop.Models.TaiKhoan;
    var loaiGia = ViewBag.LoaiGia as CarShop.Models.LoaiGia;
}

<div class="card shadow-sm">
    <div class="card-header bg-danger text-white">
        <h4><i class="fas fa-exclamation-triangle"></i> Xác nhận xóa khách hàng</h4>
    </div>
    <div class="card-body">
        <div class="alert alert-warning">
            <i class="fas fa-info-circle"></i> Bạn có chắc chắn muốn xóa khách hàng <strong>@Model.HOTEN</strong>? Hành động không thể hoàn tác.
        </div>
        <dl class="row">
            <dt class="col-sm-3">ID KH</dt>
            <dd class="col-sm-9">@Model.IDKH</dd>
            <dt class="col-sm-3">Họ tên</dt>
            <dd class="col-sm-9">@Model.HOTEN</dd>
            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@Model.EMAIL</dd>
            <dt class="col-sm-3">Số điện thoại</dt>
            <dd class="col-sm-9">@Model.DIENTHOAI</dd>
            <dt class="col-sm-3">Địa chỉ</dt>
            <dd class="col-sm-9">@Model.DIACHI</dd>
            <dt class="col-sm-3">Tài khoản</dt>
            <dd class="col-sm-9">@(taiKhoan?.TENDANGNHAP ?? "Không")</dd>
            <dt class="col-sm-3">Hạng</dt>
            <dd class="col-sm-9">@(loaiGia?.TENLOAI ?? "N/A")</dd>
        </dl>
        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="IDKH" />
            <button type="submit" class="btn btn-danger"><i class="fas fa-trash-alt"></i> Xóa</button>
            <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Quay lại</a>
        </form>
    </div>
</div>