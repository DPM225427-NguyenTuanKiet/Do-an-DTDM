@model CarShop.Models.DiemTichLuy
@{
    ViewData["Title"] = "Xóa điểm tích lũy";
    Layout = "_AdminLayout";
    var khachHang = ViewBag.KhachHang as CarShop.Models.KhachHang;
}

<div class="card shadow-sm">
    <div class="card-header bg-danger text-white">
        <h4><i class="fas fa-exclamation-triangle"></i> Xác nhận xóa điểm tích lũy</h4>
    </div>
    <div class="card-body">
        <div class="alert alert-warning">
            <i class="fas fa-info-circle"></i> Bạn có chắc chắn muốn xóa điểm tích lũy của khách hàng <strong>@(khachHang?.HOTEN)</strong>? Hành động này không thể hoàn tác.
        </div>
        <dl class="row">
            <dt class="col-sm-3">ID KH</dt>
            <dd class="col-sm-9">@Model.IDKH</dd>
            <dt class="col-sm-3">Khách hàng</dt>
            <dd class="col-sm-9">@(khachHang?.HOTEN)</dd>
            <dt class="col-sm-3">Điểm hiện tại</dt>
            <dd class="col-sm-9">@(Model.DIEMHIENTAI ?? 0)</dd>
        </dl>
        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="IDKH" />
            <button type="submit" class="btn btn-danger"><i class="fas fa-trash-alt"></i> Xóa</button>
            <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Quay lại</a>
        </form>
    </div>
</div>