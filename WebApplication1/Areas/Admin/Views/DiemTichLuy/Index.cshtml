@model List<CarShop.Areas.Admin.Controllers.DiemTichLuyViewModel>
@{
    ViewData["Title"] = "Quản lý điểm tích lũy";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold text-dark mb-0">
        <i class="fas fa-star text-warning me-2"></i> @ViewData["Title"]
    </h3>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body p-3">
        <form method="get" asp-action="Index" class="row m-0">
            <div class="col-md-6 ps-0">
                <div class="search-bar w-100">
                    <i class="fas fa-search ms-2"></i>
                    <input type="text" name="search" class="form-control border-0 bg-transparent shadow-none"
                           placeholder="Tìm theo ID KH, tên hoặc email..." value="@ViewBag.Search" autocomplete="off" />
                    <button type="submit" class="btn"><i class="fas fa-arrow-right"></i></button>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-custom table-hover align-middle mb-0">
                <thead class="table-light text-muted">
                    <tr>
                        <th class="ps-4">ID KH</th>
                        <th>Khách hàng</th>
                        <th>Email</th>
                        <th class="text-center">Điểm hiện tại</th>
                        <th class="text-center">Đã dùng</th>
                        <th>Cập nhật lần cuối</th>
                        <th class="text-center pe-4">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-dark">#@item.Diem.IDKH</td>
                                <td class="fw-medium text-primary">@(item.KhachHang?.HOTEN ?? "N/A")</td>
                                <td class="text-muted">@(item.KhachHang?.EMAIL ?? "N/A")</td>
                                <td class="text-center">
                                    <span class="badge bg-success rounded-pill px-3 fs-6 shadow-sm">@(item.Diem.DIEMHIENTAI ?? 0)</span>
                                </td>
                                <td class="text-center">
                                    <span class="badge bg-secondary rounded-pill px-3">@(item.Diem.TONGDIEMDADUNG ?? 0)</span>
                                </td>
                                <td>@(item.Diem.NGAYCAPNHAT?.ToString("dd/MM/yyyy HH:mm") ?? "")</td>
                                <td class="text-center pe-4">
                                    <div class="btn-group shadow-sm">
                                        <a asp-action="Details" asp-route-id="@item.Diem.IDKH" class="btn btn-outline-info btn-sm" title="Xem chi tiết">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.Diem.IDKH" class="btn btn-outline-warning btn-sm" title="Sửa">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Diem.IDKH" class="btn btn-outline-danger btn-sm" onclick="return confirm('Bạn có chắc chắn muốn xóa điểm của khách hàng này?');" title="Xóa">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">
                                <i class="fas fa-star fs-1 mb-3 text-warning opacity-50"></i>
                                <p class="mb-0">Không có dữ liệu điểm tích lũy.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (ViewBag.TotalPages != null && ViewBag.TotalPages > 1)
{
    <nav class="mt-4">
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.Page ? "active" : "")">
                    <a class="page-link shadow-sm mx-1 rounded-3" href="@Url.Action("Index", new { search = ViewBag.Search, page = i, pageSize = ViewBag.PageSize })">@i</a>
                </li>
            }
        </ul>
    </nav>
}