@model List<CarShop.Models.PhieuLuong>
@{
    ViewData["Title"] = "Quản lý phiếu lương";
    Layout = "_AdminLayout";
    var nhanViens = ViewBag.NhanViens as List<CarShop.Models.NhanVien>;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-file-invoice-dollar me-2"></i>Quản lý phiếu lương</h2>
    <a asp-action="Create" class="btn btn-orange"><i class="fas fa-plus"></i> Tạo phiếu lương</a>
</div>

<div class="row mb-3">
    <div class="col-md-4">
        <form method="get" asp-action="Index" class="search-bar">
            <i class="fas fa-search"></i>
            <input type="text" name="search" placeholder="Tìm theo ID NV, tháng, năm..." value="@ViewBag.Search" autocomplete="off">
            <button type="submit"><i class="fas fa-arrow-right"></i></button>
        </form>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-custom table-hover align-middle">
        <thead>
            <tr>
                <th>ID PL</th>
                <th>Nhân viên</th>
                <th>Tháng</th>
                <th>Năm</th>
                <th>Lương CB</th>
                <th>Hoa hồng</th>
                <th>Thưởng điểm</th>
                <th>Giờ làm</th>
                <th>Tổng lĩnh</th>
                <th>Ngày thanh toán</th>
                <th>Trạng thái</th>
                <th>Hành động</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Any())
            {
                foreach (var item in Model)
                {
                    var nv = nhanViens?.FirstOrDefault(n => n.IDNV == item.IDNV);
                    <tr>
                        <td>@item.IDPL</td
                        <td>@(nv?.HOTEN ?? "N/A")</td
                        <td>@(item.THANG ?? 0)</td
                        <td>@(item.NAM ?? 0)</td
                        <td>@(item.LUONG_CO_BAN?.ToString("N0") ?? "0")</td
                        <td>@(item.HOA_HONG?.ToString("N0") ?? "0")</td
                        <td>@(item.TIEN_THUONG_DIEM?.ToString("N0") ?? "0")</td
                        <td>@(item.SO_GIO_LAM ?? 0)</td
                        <td>@(item.TONG_LINH?.ToString("N0") ?? "0")</td
                        <td>@(item.NGAY_THANH_TOAN?.ToString("dd/MM/yyyy") ?? "")</td
                        <td>
                            @if (item.TRANG_THAI == "Đã thanh toán")
                            {
                                <span class="badge bg-success">Đã thanh toán</span>
                            }
                            else
                            {
                                <span class="badge bg-warning">Chưa thanh toán</span>
                            }
                         </td
                        <td>
                            <a asp-action="Details" asp-route-id="@item.IDPL" class="btn btn-sm btn-info"><i class="fas fa-eye"></i></a>
                            <a asp-action="Edit" asp-route-id="@item.IDPL" class="btn btn-sm btn-warning"><i class="fas fa-edit"></i></a>
                            <a asp-action="Delete" asp-route-id="@item.IDPL" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></a>
                         </td
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="12" class="text-center">Không có phiếu lương nào</td></tr>
            }
        </tbody>
    </table>
</div>

@if (ViewBag.TotalPages > 1)
{
    <nav class="mt-4">
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.Page ? "active" : "")">
                    <a class="page-link" href="@Url.Action("Index", new { search = ViewBag.Search, page = i, pageSize = ViewBag.PageSize })">@i</a>
                </li>
            }
        </ul>
    </nav>
}