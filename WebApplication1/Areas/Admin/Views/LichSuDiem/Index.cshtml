@model List<CarShop.Models.LichSuDiem>
@{
    ViewData["Title"] = "Lịch sử điểm tích lũy";
    Layout = "_AdminLayout";
    var khachHangs = ViewBag.KhachHangs as List<CarShop.Models.KhachHang>;
    var donHangs = ViewBag.DonHangs as List<CarShop.Models.DonHang>;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-coins me-2"></i>Lịch sử điểm tích lũy</h2>
</div>

<div class="row mb-3">
    <div class="col-md-4">
        <form method="get" asp-action="Index" class="search-bar">
            <i class="fas fa-search"></i>
            <input type="text" name="search" placeholder="Tìm theo ID KH, ID đơn, ghi chú..." value="@ViewBag.Search" autocomplete="off" />
            <button type="submit"><i class="fas fa-arrow-right"></i></button>
        </form>
    </div>
    <div class="col-md-3">
        <select name="loai" class="form-select" onchange="this.form.submit()" form="filterForm">
            <option value="all" selected="@(ViewBag.Loai == null || ViewBag.Loai == "all")">Tất cả loại</option>
            <option value="Tích lũy" selected="@(ViewBag.Loai == "Tích lũy")">Tích lũy</option>
            <option value="Tiêu dùng" selected="@(ViewBag.Loai == "Tiêu dùng")">Tiêu dùng</option>
        </select>
    </div>
</div>
<form id="filterForm" method="get" asp-action="Index">
    <input type="hidden" name="search" value="@ViewBag.Search" />
    <input type="hidden" name="loai" id="hdLoai" />
</form>

<div class="table-responsive">
    <table class="table table-custom table-hover align-middle">
        <thead>
            <tr>
                <th>ID</th>
                <th>Khách hàng</th>
                <th>Đơn hàng</th>
                <th>Số điểm</th>
                <th>Loại</th>
                <th>Ngày</th>
                <th>Ghi chú</th>
                <th>Hành động</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Any())
            {
                foreach (var item in Model)
                {
                    var kh = khachHangs?.FirstOrDefault(k => k.IDKH == item.IDKH);
                    var dh = donHangs?.FirstOrDefault(d => d.IDDH == item.IDDH);
                    <tr>
                        <td>@item.ID</td>
                        <td>@(kh?.HOTEN ?? "N/A") (ID: @item.IDKH)</td>
                        <td>@(item.IDDH.HasValue ? $"#{item.IDDH}" : "N/A")</td>
                        <td>@item.SODIEM</td>
                        <td>
                            @if (item.LOAI == "Tích lũy")
                            {
                                <span class="badge bg-success">Tích lũy</span>
                            }
                            else
                            {
                                <span class="badge bg-warning">Tiêu dùng</span>
                            }
                          </td>
                        <td>@(item.NGAY?.ToString("dd/MM/yyyy HH:mm") ?? "")</td>
                        <td>@(item.GHICHU ?? "")</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.ID" class="btn btn-sm btn-info"><i class="fas fa-eye"></i></a>
                            <a asp-action="Delete" asp-route-id="@item.ID" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></a>
                          </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="8" class="text-center">Không có dữ liệu</td></tr>
            }
        </tbody>
    </table>
</div>

@if (ViewBag.TotalPages > 1)
{
    <nav class="mt-4">
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.Page ? "active" : "")">
                    <a class="page-link" href="@Url.Action("Index", new { search = ViewBag.Search, loai = ViewBag.Loai, page = i, pageSize = ViewBag.PageSize })">@i</a>
                </li>
            }
        </ul>
    </nav>
}

@section Scripts {
    <script>
        document.querySelector('select[name="loai"]').addEventListener('change', function() {
            document.getElementById('hdLoai').value = this.value;
            document.getElementById('filterForm').submit();
        });
    </script>
}