@model List<CarShop.Models.HoaDon>
@{
    ViewData["Title"] = "Quản lý hóa đơn";
    Layout = "_AdminLayout";
    var donHangs = ViewBag.DonHangs as List<CarShop.Models.DonHang>;
    var nhanViens = ViewBag.NhanViens as List<CarShop.Models.NhanVien>;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-file-invoice me-2"></i>Quản lý hóa đơn</h2>
    <a asp-action="Create" class="btn btn-orange"><i class="fas fa-plus"></i> Thêm mới</a>
</div>

<div class="row mb-3">
    <div class="col-md-4">
        <form method="get" asp-action="Index" class="search-bar">
            <i class="fas fa-search"></i>
            <input type="text" name="search" placeholder="Tìm theo ID, đơn hàng, nhân viên..." value="@ViewBag.Search" autocomplete="off">
            <button type="submit"><i class="fas fa-arrow-right"></i></button>
        </form>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-custom table-hover align-middle">
        <thead>
            <tr>
                <th>ID HD</th>
                <th>Đơn hàng</th>
                <th>Nhân viên</th>
                <th>Ngày lập</th>
                <th>Tổng tiền</th>
                <th>Hình thức TT</th>
                <th>Trạng thái</th>
                <th>TT thanh toán</th>
                <th>Hành động</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Any())
            {
                foreach (var item in Model)
                {
                    var donHang = donHangs?.FirstOrDefault(d => d.IDDH == item.IDDH);
                    var nhanVien = nhanViens?.FirstOrDefault(n => n.IDNV == item.IDNV);
                    <tr>
                        <td>@item.IDHD</td>
                        <td>@(donHang != null ? $"#{donHang.IDDH}" : "N/A")</td>
                        <td>@(nhanVien?.HOTEN ?? "N/A")</td>
                        <td>@(item.NGAYLAP?.ToString("dd/MM/yyyy HH:mm") ?? "")</td>
                        <td>@(item.TONGTIEN?.ToString("N0") ?? "0") VNĐ</td>
                        <td>@(item.HINHTHUCTHANHTOAN ?? "")</td>
                        <td>@(item.TRANGTHAI ?? "")</td>
                        <td>@(item.TRANGTHAITHANHTOAN ?? "")</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.IDHD" class="btn btn-sm btn-info"><i class="fas fa-eye"></i></a>
                            <a asp-action="Edit" asp-route-id="@item.IDHD" class="btn btn-sm btn-warning"><i class="fas fa-edit"></i></a>
                            <a asp-action="Delete" asp-route-id="@item.IDHD" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="9" class="text-center">Không có hóa đơn nào</td></tr>
            }
        </tbody>
    </table>
</div>

@if (ViewBag.TotalPages > 1)
{
    <nav class="mt-4">
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.Page ? "active" : "")">
                    <a class="page-link" href="@Url.Action("Index", new { search = ViewBag.Search, page = i, pageSize = ViewBag.PageSize })">@i</a>
                </li>
            }
        </ul>
    </nav>
}
