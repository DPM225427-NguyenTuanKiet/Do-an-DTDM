@model List<CarShop.Models.HoaDon>
@{
    ViewData["Title"] = "Quản lý hóa đơn";
    Layout = "_AdminLayout";
    var donHangs = ViewBag.DonHangs as List<CarShop.Models.DonHang>;
    var nhanViens = ViewBag.NhanViens as List<CarShop.Models.NhanVien>;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold text-dark mb-0">
        <i class="fas fa-file-invoice text-primary me-2"></i> @ViewData["Title"]
    </h3>
    <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm">
        <i class="fas fa-plus me-1"></i> Thêm mới
    </a>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body p-3">
        <form method="get" asp-action="Index" class="row m-0">
            <div class="col-md-6 ps-0">
                <div class="search-bar w-100">
                    <i class="fas fa-search ms-2"></i>
                    <input type="text" name="search" class="form-control border-0 bg-transparent shadow-none"
                           placeholder="Tìm theo ID, đơn hàng, nhân viên..." value="@ViewBag.Search" autocomplete="off">
                    <button type="submit" class="btn"><i class="fas fa-arrow-right"></i></button>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-custom table-hover align-middle mb-0">
                <thead class="table-light text-muted">
                    <tr>
                        <th class="ps-4">ID HD</th>
                        <th>Đơn hàng</th>
                        <th>Nhân viên</th>
                        <th>Ngày lập</th>
                        <th>Tổng tiền</th>
                        <th>Hình thức TT</th>
                        <th>Trạng thái</th>
                        <th>TT thanh toán</th>
                        <th class="text-center pe-4">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            var donHang = donHangs?.FirstOrDefault(d => d.IDDH == item.IDDH);
                            var nhanVien = nhanViens?.FirstOrDefault(n => n.IDNV == item.IDNV);
                            <tr>
                                <td class="ps-4 fw-bold text-dark">#@item.IDHD</td>
                                <td>
                                    @if (donHang != null)
                                    {
                                        <span class="badge bg-light text-dark border shadow-sm">#@donHang.IDDH</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">N/A</span>
                                    }
                                </td>
                                <td class="fw-medium text-primary">@(nhanVien?.HOTEN ?? "N/A")</td>
                                <td>@(item.NGAYLAP?.ToString("dd/MM/yyyy HH:mm") ?? "")</td>
                                <td class="fw-bold text-danger">@(item.TONGTIEN?.ToString("N0") ?? "0") đ</td>
                                <td>@(item.HINHTHUCTHANHTOAN ?? "")</td>
                                <td>
                                    @if (item.TRANGTHAI == "Đã xử lý" || item.TRANGTHAI == "Hoàn thành" || item.TRANGTHAI == "Đã giao")
                                    {
                                        <span class="badge bg-success rounded-pill px-3">@item.TRANGTHAI</span>
                                    }
                                    else if (item.TRANGTHAI == "Đã hủy")
                                    {
                                        <span class="badge bg-danger rounded-pill px-3">@item.TRANGTHAI</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark rounded-pill px-3">@(item.TRANGTHAI ?? "Đang xử lý")</span>
                                    }
                                </td>
                                <td>
                                    @if (item.TRANGTHAITHANHTOAN == "Đã thanh toán")
                                    {
                                        <span class="badge border border-success text-success px-2 py-1"><i class="fas fa-check-circle me-1"></i>Đã TT</span>
                                    }
                                    else
                                    {
                                        <span class="badge border border-warning text-warning px-2 py-1"><i class="fas fa-clock me-1"></i>Chưa TT</span>
                                    }
                                </td>
                                <td class="text-center pe-4">
                                    <div class="btn-group shadow-sm">
                                        <a asp-action="Details" asp-route-id="@item.IDHD" class="btn btn-outline-info btn-sm" title="Xem chi tiết">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.IDHD" class="btn btn-outline-warning btn-sm" title="Sửa">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.IDHD" class="btn btn-outline-danger btn-sm" onclick="return confirm('Bạn có chắc chắn muốn xóa hóa đơn này?');" title="Xóa">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="9" class="text-center py-5 text-muted">
                                <i class="fas fa-file-invoice fs-1 mb-3 opacity-50"></i>
                                <p class="mb-0">Không có hóa đơn nào.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (ViewBag.TotalPages != null && ViewBag.TotalPages > 1)
{
    <nav class="mt-4">
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.Page ? "active" : "")">
                    <a class="page-link shadow-sm mx-1 rounded-3" href="@Url.Action("Index", new { search = ViewBag.Search, page = i, pageSize = ViewBag.PageSize })">@i</a>
                </li>
            }
        </ul>
    </nav>
}