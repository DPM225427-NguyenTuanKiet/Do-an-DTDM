@model CarShop.Models.HoaDon
@{
    ViewData["Title"] = "Xóa hóa đơn";
    Layout = "_AdminLayout";
    var donHang = ViewBag.DonHang as CarShop.Models.DonHang;
    var nhanVien = ViewBag.NhanVien as CarShop.Models.NhanVien;
}

<div class="card shadow-sm">
    <div class="card-header bg-danger text-white">
        <h4><i class="fas fa-exclamation-triangle"></i> Xác nhận xóa hóa đơn</h4>
    </div>
    <div class="card-body">
        <div class="alert alert-warning">
            <i class="fas fa-info-circle"></i> Bạn có chắc chắn muốn xóa hóa đơn #@Model.IDHD? Hành động không thể hoàn tác.
        </div>
        <dl class="row">
            <dt class="col-sm-3">ID Hóa đơn</dt>
            <dd class="col-sm-9">@Model.IDHD</dd>
            <dt class="col-sm-3">Đơn hàng</dt>
            <dd class="col-sm-9">@(donHang != null ? $"#{donHang.IDDH}" : "N/A")</dd>
            <dt class="col-sm-3">Nhân viên</dt>
            <dd class="col-sm-9">@(nhanVien?.HOTEN ?? "N/A")</dd>
            <dt class="col-sm-3">Tổng tiền</dt>
            <dd class="col-sm-9">@(Model.TONGTIEN?.ToString("N0") ?? "0") VNĐ</dd>
        </dl>
        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="IDHD" />
            <button type="submit" class="btn btn-danger"><i class="fas fa-trash-alt"></i> Xóa</button>
            <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Quay lại</a>
        </form>
    </div>
</div>