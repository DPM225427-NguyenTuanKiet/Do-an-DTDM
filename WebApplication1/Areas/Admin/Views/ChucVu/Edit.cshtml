@model CarShop.Models.ChucVu
@{
    ViewData["Title"] = "Sửa chức vụ";
    Layout = "_AdminLayout";
}

<div class="card shadow-sm">
    <div class="card-header bg-warning text-dark">
        <h4><i class="fas fa-edit"></i> Sửa chức vụ</h4>
    </div>
    <div class="card-body">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="IDCV" />
            <div class="mb-3">
                <label asp-for="TENCV" class="form-label">Tên chức vụ</label>
                <input asp-for="TENCV" class="form-control" required />
            </div>
            <div class="mb-3">
                <label asp-for="MOTA" class="form-label">Mô tả</label>
                <textarea asp-for="MOTA" class="form-control" rows="3"></textarea>
            </div>
            <button type="submit" class="btn btn-orange"><i class="fas fa-save"></i> Lưu thay đổi</button>
            <a asp-action="Index" class="btn btn-secondary">Hủy</a>
        </form>
    </div>
</div>