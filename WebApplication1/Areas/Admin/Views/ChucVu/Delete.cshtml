@model CarShop.Models.ChucVu
@{
    ViewData["Title"] = "Xóa chức vụ";
    Layout = "_AdminLayout";
}

<div class="card shadow-sm">
    <div class="card-header bg-danger text-white">
        <h4><i class="fas fa-exclamation-triangle"></i> Xác nhận xóa chức vụ</h4>
    </div>
    <div class="card-body">
        <div class="alert alert-warning">
            <i class="fas fa-info-circle"></i> Bạn có chắc chắn muốn xóa chức vụ <strong>@Model.TENCV</strong>? Hành động này không thể hoàn tác.
        </div>
        <dl class="row">
            <dt class="col-sm-3">ID</dt>
            <dd class="col-sm-9">@Model.IDCV</dd>
            <dt class="col-sm-3">Tên chức vụ</dt>
            <dd class="col-sm-9">@Model.TENCV</dd>
            <dt class="col-sm-3">Mô tả</dt>
            <dd class="col-sm-9">@(Model.MOTA ?? "")</dd>
        </dl>
        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="IDCV" />
            <button type="submit" class="btn btn-danger"><i class="fas fa-trash-alt"></i> Xóa</button>
            <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Quay lại</a>
        </form>
    </div>
</div>