@model CarShop.Models.ChucVu
@{
    ViewData["Title"] = "Thêm chức vụ";
    Layout = "_AdminLayout";
}

<div class="card shadow-sm">
    <div class="card-header bg-success text-white">
        <h4><i class="fas fa-plus"></i> Thêm chức vụ mới</h4>
    </div>
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div class="mb-3">
                <label asp-for="TENCV" class="form-label">Tên chức vụ</label>
                <input asp-for="TENCV" class="form-control" required />
            </div>
            <div class="mb-3">
                <label asp-for="MOTA" class="form-label">Mô tả</label>
                <textarea asp-for="MOTA" class="form-control" rows="3"></textarea>
            </div>
            <button type="submit" class="btn btn-orange"><i class="fas fa-save"></i> Lưu</button>
            <a asp-action="Index" class="btn btn-secondary">Hủy</a>
        </form>
    </div>
</div>