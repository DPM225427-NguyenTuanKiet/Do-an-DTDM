@model List<CarShop.Models.KhuyenMai>
@{
    ViewData["Title"] = "Quản lý khuyến mãi";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-tags me-2"></i>Quản lý khuyến mãi</h2>
    <a asp-action="Create" class="btn btn-orange"><i class="fas fa-plus"></i> Thêm khuyến mãi</a>
</div>

<div class="row mb-3">
    <div class="col-md-4">
        <form method="get" asp-action="Index" class="search-bar">
            <i class="fas fa-search"></i>
            <input type="text" name="search" placeholder="Tìm theo tên hoặc % giảm..." value="@ViewBag.Search" autocomplete="off">
            <button type="submit"><i class="fas fa-arrow-right"></i></button>
        </form>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-custom table-hover align-middle">
        <thead>
            <tr>
                <th>ID KM</th>
                <th>Tên khuyến mãi</th>
                <th>% giảm</th>
                <th>Ngày bắt đầu</th>
                <th>Ngày kết thúc</th>
                <th>Trạng thái</th>
                <th>Sản phẩm áp dụng</th>
                <th>Hành động</th>
            </tr>
        </thead>
        <tbody>
    @if (Model.Any())
    {
        foreach (var item in Model)
        {
            <tr>
                <td>@item.IDKM</td
                <td>@(item.TENKM ?? "")</td
                <td>@(item.PHANTRAMGIAM?.ToString() ?? "0")%</td
                <td>@(item.NGAYBATDAU?.ToString("dd/MM/yyyy") ?? "")</td
                <td>@(item.NGAYKETTHUC?.ToString("dd/MM/yyyy") ?? "")</td
                <td>
                    @if (item.TRANGTHAI == true)
                    {
                        <span class="badge bg-success">Đang áp dụng</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Đã kết thúc</span>
                    }
                 </td>
                <td>
                    <a asp-area="Admin" asp-controller="SanPhamKhuyenMai" asp-action="Index" asp-route-search="@item.IDKM" class="btn btn-sm btn-info">Xem SP</a>
                 </td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.IDKM" class="btn btn-sm btn-info"><i class="fas fa-eye"></i></a>
                    <a asp-action="Edit" asp-route-id="@item.IDKM" class="btn btn-sm btn-warning"><i class="fas fa-edit"></i></a>
                    <a asp-action="Delete" asp-route-id="@item.IDKM" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></a>
                    <a asp-area="Admin" asp-controller="SanPhamKhuyenMai" asp-action="Create" asp-route-kmId="@item.IDKM" class="btn btn-sm btn-success">Thêm SP</a>
                 </td>
            </tr>
        }
    }
            else
            {
                <tr><td colspan="7" class="text-center">Không có khuyến mãi nào</td></tr>
            }
        </tbody>
    </table>
</div>

@if (ViewBag.TotalPages > 1)
{
    <nav class="mt-4">
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.Page ? "active" : "")">
                    <a class="page-link" href="@Url.Action("Index", new { search = ViewBag.Search, page = i, pageSize = ViewBag.PageSize })">@i</a>
                </li>
            }
        </ul>
    </nav>
}