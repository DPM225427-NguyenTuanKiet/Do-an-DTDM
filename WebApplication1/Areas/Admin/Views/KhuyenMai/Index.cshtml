@model IEnumerable<CarShop.Models.KhuyenMai>
@{
    ViewData["Title"] = "Quản lý Khuyến mãi";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold text-dark mb-0">
        <i class="fas fa-tags text-primary me-2"></i> @ViewData["Title"]
    </h3>
    <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm">
        <i class="fas fa-plus me-1"></i> Thêm khuyến mãi
    </a>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body p-3">
        <form method="get" class="d-flex align-items-center">
            <div class="search-bar w-50">
                <i class="fas fa-search ms-2"></i>
                <input type="text" name="search" class="form-control border-0 bg-transparent shadow-none"
                       placeholder="Tìm theo tên hoặc % giảm..." value="@Context.Request.Query["search"]">
                <button type="submit" class="btn"><i class="fas fa-arrow-right"></i></button>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-custom table-hover align-middle mb-0">
                <thead class="table-light text-muted">
                    <tr>
                        <th class="ps-4">ID KM</th>
                        <th>Tên khuyến mãi</th>
                        <th>% giảm</th>
                        <th>Ngày bắt đầu</th>
                        <th>Ngày kết thúc</th>
                        <th>Trạng thái</th>
                        <th class="text-center">Sản phẩm áp dụng</th>
                        <th class="text-center pe-4">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-dark">@item.IDKM</td>
                                <td class="fw-medium">@item.TENKM</td>
                                <td><span class="badge bg-danger rounded-pill px-3">@item.PHANTRAMGIAM%</span></td>
                                <td>@item.NGAYBATDAU?.ToString("dd/MM/yyyy")</td>
                                <td>@item.NGAYKETTHUC?.ToString("dd/MM/yyyy")</td>
                                <td>
                                    @if (item.NGAYKETTHUC >= DateTime.Now && item.NGAYBATDAU <= DateTime.Now)
                                    {
                                        <span class="badge bg-success rounded-pill px-3">Đang áp dụng</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary rounded-pill px-3">Hết hạn</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <a href="#" class="btn btn-info btn-sm text-white rounded-pill px-3">
                                        Xem SP
                                    </a>
                                </td>
                                <td class="text-center pe-4">
                                    <div class="btn-group shadow-sm">
                                        <a asp-action="Details" asp-route-id="@item.IDKM" class="btn btn-outline-info btn-sm" title="Xem chi tiết">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.IDKM" class="btn btn-outline-warning btn-sm" title="Sửa">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.IDKM" class="btn btn-outline-danger btn-sm" title="Xóa">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </div>
                                    <a asp-action="AddProduct" asp-route-id="@item.IDKM" class="btn btn-success btn-sm ms-1 rounded-pill">
                                        <i class="fas fa-plus-circle me-1"></i> Thêm SP
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center py-5 text-muted">
                                <i class="fas fa-box-open fs-1 mb-3 opacity-50"></i>
                                <p class="mb-0">Chưa có chương trình khuyến mãi nào.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>