@model CarShop.Models.KhuyenMai
@{
    ViewData["Title"] = "Xóa khuyến mãi";
    Layout = "_AdminLayout";
}

<div class="card shadow-sm">
    <div class="card-header bg-danger text-white">
        <h4><i class="fas fa-exclamation-triangle"></i> Xác nhận xóa khuyến mãi</h4>
    </div>
    <div class="card-body">
        <div class="alert alert-warning">
            <i class="fas fa-info-circle"></i> Bạn có chắc chắn muốn xóa khuyến mãi <strong>@(Model.TENKM ?? "này")</strong>? Hành động không thể hoàn tác.
        </div>
        <dl class="row">
            <dt class="col-sm-3">ID KM</dt>
            <dd class="col-sm-9">@Model.IDKM</dd>
            <dt class="col-sm-3">Tên khuyến mãi</dt>
            <dd class="col-sm-9">@(Model.TENKM ?? "")</dd>
            <dt class="col-sm-3">% giảm</dt>
            <dd class="col-sm-9">@(Model.PHANTRAMGIAM?.ToString() ?? "0")%</dd>
            <dt class="col-sm-3">Ngày bắt đầu</dt>
            <dd class="col-sm-9">@(Model.NGAYBATDAU?.ToString("dd/MM/yyyy") ?? "")</dd>
            <dt class="col-sm-3">Ngày kết thúc</dt>
            <dd class="col-sm-9">@(Model.NGAYKETTHUC?.ToString("dd/MM/yyyy") ?? "")</dd>
        </dl>
        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="IDKM" />
            <button type="submit" class="btn btn-danger"><i class="fas fa-trash-alt"></i> Xóa</button>
            <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Quay lại</a>
        </form>
    </div>
</div>
