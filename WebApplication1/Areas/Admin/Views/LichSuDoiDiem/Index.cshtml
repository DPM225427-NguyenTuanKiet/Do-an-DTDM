@model List<CarShop.Models.LichSuDoiDiem>
@{
    ViewData["Title"] = "Lịch sử đổi điểm";
    Layout = "_AdminLayout";
    var khachHangs = ViewBag.KhachHangs as List<CarShop.Models.KhachHang>;
    var vouchers = ViewBag.Vouchers as List<CarShop.Models.Voucher>;
    var quaTangs = ViewBag.QuaTangs as List<CarShop.Models.QuaTang>;
    var donHangs = ViewBag.DonHangs as List<CarShop.Models.DonHang>;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-exchange-alt me-2"></i>Lịch sử đổi điểm</h2>
    <a asp-action="Create" class="btn btn-orange"><i class="fas fa-plus"></i> Thêm mới</a>
</div>

<div class="row mb-3">
    <div class="col-md-4">
        <form method="get" asp-action="Index" class="search-bar">
            <i class="fas fa-search"></i>
            <input type="text" name="search" placeholder="Tìm theo ID KH, đơn hàng, voucher, quà..." value="@ViewBag.Search" autocomplete="off" />
            <button type="submit"><i class="fas fa-arrow-right"></i></button>
        </form>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-custom table-hover align-middle">
        <thead>
            <tr>
                <th>ID</th>
                <th>Khách hàng</th>
                <th>Đơn hàng</th>
                <th>Voucher</th>
                <th>Quà tặng</th>
                <th>Số điểm đổi</th>
                <th>Tiền giảm</th>
                <th>Ngày đổi</th>
                <th>Trạng thái</th>
                <th>Hành động</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Any())
            {
                foreach (var item in Model)
                {
                    var kh = khachHangs?.FirstOrDefault(k => k.IDKH == item.IDKH);
                    var voucher = item.IDV.HasValue ? vouchers?.FirstOrDefault(v => v.IDV == item.IDV) : null;
                    var quaTang = item.IDQT.HasValue ? quaTangs?.FirstOrDefault(q => q.IDQT == item.IDQT) : null;
                    var donHang = item.IDDONHANG.HasValue ? donHangs?.FirstOrDefault(d => d.IDDH == item.IDDONHANG) : null;
                    <tr>
                        <td>@item.ID</td>
                        <td>@(kh?.HOTEN ?? "N/A")</td>
                        <td>@(donHang != null ? $"#{donHang.IDDH}" : "N/A")</td>
                        <td>@(voucher?.TENVOUCHER ?? "N/A")</td>
                        <td>@(quaTang?.TENQUATANG ?? "N/A")</td>
                        <td>@item.SODIEM_DOI</td>
                        <td>@(item.SOTIENGIAM?.ToString("N0") ?? "0") VNĐ</td>
                        <td>@item.NGAYDOI.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@item.TRANGTHAI</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.ID" class="btn btn-sm btn-info"><i class="fas fa-eye"></i></a>
                            <a asp-action="Edit" asp-route-id="@item.ID" class="btn btn-sm btn-warning"><i class="fas fa-edit"></i></a>
                            <a asp-action="Delete" asp-route-id="@item.ID" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></a>
                         </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="10" class="text-center">Không có dữ liệu</td></tr>
            }
        </tbody>
    </table>
</div>

@if (ViewBag.TotalPages > 1)
{
    <nav class="mt-4">
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.Page ? "active" : "")">
                    <a class="page-link" href="@Url.Action("Index", new { search = ViewBag.Search, page = i, pageSize = ViewBag.PageSize })">@i</a>
                </li>
            }
        </ul>
    </nav>
}