@model CarShop.Models.LichSuDoiDiem
@{
    ViewData["Title"] = "Chi tiết lịch sử đổi điểm";
    Layout = "_AdminLayout";
    var khachHang = ViewBag.KhachHang as CarShop.Models.KhachHang;
    var voucher = ViewBag.Voucher as CarShop.Models.Voucher;
    var quaTang = ViewBag.QuaTang as CarShop.Models.QuaTang;
    var donHang = ViewBag.DonHang as CarShop.Models.DonHang;
}

<div class="card shadow-sm">
    <div class="card-header bg-primary text-white">
        <h4><i class="fas fa-info-circle"></i> Chi tiết lịch sử đổi điểm #@Model.ID</h4>
    </div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">ID</dt>
            <dd class="col-sm-9">@Model.ID</dd>
            <dt class="col-sm-3">Khách hàng</dt>
            <dd class="col-sm-9">@(khachHang?.HOTEN ?? "N/A")</dd>
            <dt class="col-sm-3">Đơn hàng</dt>
            <dd class="col-sm-9">@(donHang != null ? $"#{donHang.IDDH}" : "Không")</dd>
            <dt class="col-sm-3">Voucher</dt>
            <dd class="col-sm-9">@(voucher?.TENVOUCHER ?? "Không")</dd>
            <dt class="col-sm-3">Quà tặng</dt>
            <dd class="col-sm-9">@(quaTang?.TENQUATANG ?? "Không")</dd>
            <dt class="col-sm-3">Số điểm đổi</dt>
            <dd class="col-sm-9">@Model.SODIEM_DOI</dd>
            <dt class="col-sm-3">Tiền giảm</dt>
            <dd class="col-sm-9">@(Model.SOTIENGIAM?.ToString("N0") ?? "0") VNĐ</dd>
            <dt class="col-sm-3">Ngày đổi</dt>
            <dd class="col-sm-9">@Model.NGAYDOI.ToString("dd/MM/yyyy HH:mm")</dd>
            <dt class="col-sm-3">Trạng thái</dt>
            <dd class="col-sm-9">@Model.TRANGTHAI</dd>
        </dl>
    </div>
    <div class="card-footer">
        <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Quay lại</a>
        <a asp-action="Edit" asp-route-id="@Model.ID" class="btn btn-warning"><i class="fas fa-edit"></i> Sửa</a>
        <a asp-action="Delete" asp-route-id="@Model.ID" class="btn btn-danger"><i class="fas fa-trash"></i> Xóa</a>
    </div>
</div>