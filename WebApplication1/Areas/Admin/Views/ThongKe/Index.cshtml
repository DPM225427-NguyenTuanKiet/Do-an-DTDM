@{
    ViewData["Title"] = "Thống kê & Báo cáo";
    Layout = "_AdminLayout";
    var dailyReports = ViewBag.DailyReports as List<CarShop.Models.BaoCaoDoanhThuNgay>;
    var monthlyReports = ViewBag.MonthlyReports as List<CarShop.Models.BaoCaoDoanhThuThang>;
    var yearlyReports = ViewBag.YearlyReports as List<CarShop.Models.BaoCaoDoanhThuNam>;
}

<div class="row mb-4">
    <div class="col-md-3">
        <div class="card stat-card bg-gradient-primary text-white">
            <div class="card-body">
                <h5 class="card-title">Tổng doanh thu</h5>
                <p class="card-text display-6">@ViewBag.TotalRevenue.ToString("N0") VNĐ</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card bg-gradient-success text-white">
            <div class="card-body">
                <h5 class="card-title">Tổng đơn hàng</h5>
                <p class="card-text display-6">@ViewBag.TotalOrders</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card bg-gradient-warning text-white">
            <div class="card-body">
                <h5 class="card-title">Đang xử lý</h5>
                <p class="card-text display-6">@ViewBag.PendingOrders</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card bg-gradient-info text-white">
            <div class="card-body">
                <h5 class="card-title">Đã giao</h5>
                <p class="card-text display-6">@ViewBag.DeliveredOrders</p>
            </div>
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-12">
        <div class="chart-container">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5>📊 Biểu đồ doanh thu</h5>
                <div>
                    <select id="chartType" class="form-select form-select-sm w-auto d-inline-block">
                        <option value="day">Theo ngày (30 ngày)</option>
                        <option value="month">Theo tháng (12 tháng)</option>
                        <option value="year">Theo năm (5 năm)</option>
                    </select>
                </div>
            </div>
            <canvas id="revenueChart" height="300"></canvas>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="chart-container">
            <h5>📈 Báo cáo doanh thu gần đây</h5>
            <ul class="nav nav-tabs" id="reportTab" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#daily" type="button">Theo ngày</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#monthly" type="button">Theo tháng</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#yearly" type="button">Theo năm</button>
                </li>
            </ul>
            <div class="tab-content mt-3">
                <div class="tab-pane fade show active" id="daily">
                    <table class="table table-sm">
                        <thead><tr><th>Ngày</th><th>Doanh thu</th><th>Số đơn</th></tr></thead>
                        <tbody>
                            @foreach (var item in dailyReports)
                            {
                                <tr>
                                    <td>@item.NGAY.ToString("dd/MM/yyyy")</td>
                                    <td>@item.TONG_DOANHTHU?.ToString("N0") VNĐ</td>
                                    <td>@item.TONG_DONHANG</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="tab-pane fade" id="monthly">
                    <table class="table table-sm">
                        <thead><tr><th>Tháng</th><th>Doanh thu</th><th>Số đơn</th></tr></thead>
                        <tbody>
                            @foreach (var item in monthlyReports)
                            {
                                <tr>
                                    <td>@item.THANG/@item.NAM</td>
                                    <td>@item.TONG_DOANHTHU?.ToString("N0") VNĐ</td>
                                    <td>@item.TONG_DONHANG</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="tab-pane fade" id="yearly">
                    <table class="table table-sm">
                        <thead><tr><th>Năm</th><th>Doanh thu</th><th>Số đơn</th></tr></thead>
                        <tbody>
                            @foreach (var item in yearlyReports)
                            {
                                <tr>
                                    <td>@item.NAM</td>
                                    <td>@item.TONG_DOANHTHU?.ToString("N0") VNĐ</td>
                                    <td>@item.TONG_DONHANG</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="chart-container">
            <h5>🔥 Top sản phẩm bán chạy</h5>
            <ul class="list-group mt-3" id="topProductsList">
                @foreach (var item in ViewBag.TopProducts)
                {
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        @item.name
                        <span class="badge bg-primary rounded-pill">@item.sold cái</span>
                    </li>
                }
            </ul>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/admin.js"></script>
}